# Database
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
DIRECT_URL=postgresql://user:password@host/db?sslmode=require
# Disposable Neon branch for integration tests (tenant-isolation, rollups, …).
# Without it those suites are SKIPPED — they must never run against prod.
TEST_DATABASE_URL=
TEST_DIRECT_URL=

# NextAuth v5
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_SECRET=same-as-nextauth-secret
AUTH_URL=https://your-domain.com/api/auth
AUTH_TRUST_HOST=true

# Google SSO (parents) — redirect URI: https://your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=from-google-cloud-console
GOOGLE_CLIENT_SECRET=from-google-cloud-console

# App URLs
NEXT_PUBLIC_APP_URL=https://your-app-domain.com
NEXT_PUBLIC_MARKETPLACE_URL=https://your-marketplace-domain.com
NEXT_PUBLIC_APP_NAME=Vidhyaan

# OTP Settings
OTP_TTL_SECONDS=600
OTP_MAX_ATTEMPTS=5

# MSG91 (SMS & WhatsApp)
MSG91_AUTH_KEY=get-from-msg91-dashboard
MSG91_SENDER_ID=VDHYVC
MSG91_OTP_TEMPLATE_ID=get-from-msg91-otp-templates
MSG91_LOGIN_TEMPLATE_ID=get-from-msg91-otp-templates
MSG91_SMS_FLOW_ID=get-from-msg91-flows
MSG91_WHATSAPP_NUMBER=your-whatsapp-business-number

# ZeptoMail (Email — primary)
ZEPTOMAIL_API_TOKEN=get-from-zeptomail-dashboard
ZEPTOMAIL_FROM_EMAIL=noreply@vidhyaan.com
ZEPTOMAIL_CAMPAIGN_EMAIL=campaigns@vidhyaan.com
# Bounce webhook shared secret (ZeptoMail auth header x-webhook-key)
ZEPTOMAIL_WEBHOOK_SECRET=any-long-random-string

# Amazon SES (Email — automatic failover; uses AWS_ACCESS_KEY_ID/SECRET above)
# Requires domain verified in SES + production access. Set EMAIL_PROVIDER=ses
# to make SES primary (e.g. if the ZeptoMail account is blocked).
# EMAIL_PROVIDER=ses
SES_REGION=ap-south-1
SES_WEBHOOK_SECRET=any-long-random-string

# Feature Flags
ENABLE_WHATSAPP=false
ENABLE_CAMPAIGNS=true
ENABLE_AI_FEATURES=false
NEXT_PUBLIC_MAINTENANCE_MODE=false

# Platform Config
VIDHYAAN_SUPER_ADMIN_EMAIL=admin@vidhyaan.com
PLATFORM_SUPPORT_EMAIL=support@vidhyaan.com

# Cron
CRON_SECRET=vidhyaan_cron_2026

# External Services
GEMINI_API_KEY=get-from-google-ai-studio
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# Razorpay (per-school, stored encrypted in DB)
# No global Razorpay keys needed here

# Payment gateway (fee collection) — secrets-at-rest encryption.
# 32 bytes base64: `openssl rand -base64 32`. Rotation: add
# PAYMENT_ENCRYPTION_KEY_V2 and set PAYMENT_ENCRYPTION_KEY_CURRENT=2.
PAYMENT_ENCRYPTION_KEY=
# Explicit opt-in mock gateway for local dev/tests (never active in production)
# PAYMENT_PROVIDER_MOCK=1
