{
  "expo": {
    "name": "Vidhyaan",
    "slug": "vidhyaan",
    "version": "0.1.0",
    "scheme": "vidhyaan",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.vidhyaan.app",
      "supportsTablet": false
    },
    "android": {
      "package": "com.vidhyaan.app",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "85a525e3-3fc9-45ba-8cf8-7ea0fc9c8388"
      }
    },
    "owner": "vimalcainadath",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/85a525e3-3fc9-45ba-8cf8-7ea0fc9c8388",
      "checkAutomatically": "ON_ERROR_RECOVERY",
      "fallbackToCacheTimeout": 0
    },
    "platforms": [
      "ios",
      "android",
      "web"
    ]
  }
}