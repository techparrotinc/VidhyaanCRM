{
  "expo": {
    "name": "Vidhyaan",
    "slug": "vidhyaan",
    "version": "0.1.0",
    "scheme": "vidhyaan",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.vidhyaan.app",
      "supportsTablet": false
    },
    "android": {
      "package": "com.vidhyaan.app",
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "SET_AFTER_eas_init"
      }
    }
  }
}
