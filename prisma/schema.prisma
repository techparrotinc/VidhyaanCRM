/// Public school/learning-center listing. May be claimed (org_id set) or scraped (org_id null).
model School {
  id                      String             @id @default(cuid())
  orgId                   String?            @map("org_id") // set when claimed by an organization
  name                    String
  slug                    String             @unique
  institutionType         InstitutionType    @map("institution_type")
  description             String?
  verificationStatus      VerificationStatus @default(UNCLAIMED) @map("verification_status")
  isVerified              Boolean            @default(false) @map("is_verified")
  profileCompletion       Int                @default(0) @map("profile_completion") // 0-100
  rankingScore            Int                @default(0) @map("ranking_score") // 0-100 search score
  avgRating               Float              @default(0) @map("avg_rating")
  reviewCount             Int                @default(0) @map("review_count")
  responseRatePct         Int?               @map("response_rate_pct")
  avgResponseHours        Int?               @map("avg_response_hours")
  admissionOpen           Boolean            @default(false) @map("admission_open")
  googlePlaceId           String?            @map("google_place_id")
  dataSource              DataSource         @default(SCRAPED) @map("data_source")
  qualityScore            Int                @default(0) @map("quality_score") // data-completeness/quality 0-100
  claimedAt               DateTime?          @map("claimed_at")
  verifiedAt              DateTime?          @map("verified_at")
  rejectionReason         String?            @map("rejection_reason")
  createdAt               DateTime           @default(now()) @map("created_at")
  updatedAt               DateTime           @updatedAt @map("updated_at")
  deletedAt               DateTime?          @map("deleted_at")
  centerCategory          String?            @map("center_category")
  isDummy                 Boolean            @default(false) @map("is_dummy")
  examFocus               String[]           @map("exam_focus")
  mediumOfInstructionList String[]           @map("medium_of_instruction_list")

  // For Learning Centers
  trialClassAvailable  Boolean  @default(false) @map("trial_class_available")
  enrollmentStatus     String   @default("OPEN") @map("enrollment_status")
  ageGroupMin          Int?     @map("age_group_min")
  ageGroupMax          Int?     @map("age_group_max")
  monthlyFeeMin        Int?     @map("monthly_fee_min")
  monthlyFeeMax        Int?     @map("monthly_fee_max")
  activityTypes        String[] @map("activity_types")
  homeVisitAvailable   Boolean  @default(false) @map("home_visit_available")
  batchCount           Int      @default(0) @map("batch_count")
  enrolledStudentCount Int      @default(0) @map("enrolled_student_count")

  // Profile data fields
  establishedYear     Int?      @map("established_year")
  totalStudents       Int?      @map("total_students")
  totalTeachers       Int?      @map("total_teachers")
  mediumOfInstruction String?   @map("medium_of_instruction")
  schoolType          String?   @map("school_type")
  gender              String?   @map("gender")
  gradesOffered       String?   @map("grades_offered")
  academicYear        String?   @map("academic_year")
  admissionDeadline   DateTime? @map("admission_deadline")
  admissionFormLink   String?   @map("admission_form_link")
  isManagedBySchool   Boolean   @default(false) @map("is_managed_by_school")
  isPublished         Boolean   @default(false) @map("is_published")
  isClaimed           Boolean   @default(false) @map("is_claimed")
  viewCount           Int       @default(0) @map("view_count")
  enquiryCount        Int       @default(0) @map("enquiry_count")

  organization    Organization?         @relation(fields: [orgId], references: [id])
  locations       SchoolLocation[]
  contacts        SchoolContact[]
  media           SchoolMedia[]
  facilities      SchoolFacility[]
  feeRanges       SchoolFeeRange[]
  affiliations    SchoolAffiliation[]
  accreditations  SchoolAccreditation[]
  hours           SchoolHours[]
  enquiries       ParentEnquiry[]
  applications    ParentApplication[]
  bookmarks       ParentBookmark[]
  views           SchoolView[]
  reviews         SchoolReview[]
  waitlistEntries WaitlistEntry[]
  openDayEvents   OpenDayEvent[]
  instructors     Instructor[]
  batchSchedules  BatchSchedule[]
  trialBookings   TrialClassBooking[]

  @@index([orgId])
  @@index([institutionType])
  @@index([isVerified])
  @@index([rankingScore])
  @@map("schools")
  @@schema("marketplace")
}

/// Geo + address record for a school (supports multiple campuses).
model SchoolLocation {
  id          String    @id @default(cuid())
  schoolId    String    @map("school_id")
  orgId       String?   @map("org_id")
  label       String?
  addressLine String?   @map("address_line")
  city        String?
  state       String?
  pincode     String?
  latitude    Float?
  longitude   Float?
  isPrimary   Boolean   @default(false) @map("is_primary")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([city])
  @@index([pincode])
  @@index([addressLine(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("school_locations")
  @@schema("marketplace")
}

/// Public contact channels for a school.
model SchoolContact {
  id        String    @id @default(cuid())
  schoolId  String    @map("school_id")
  orgId     String?   @map("org_id")
  type      String // phone, email, website, whatsapp
  value     String
  isPrimary Boolean   @default(false) @map("is_primary")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("school_contacts")
  @@schema("marketplace")
}

/// Images/videos on a school profile (free plan capped at 3 images).
model SchoolMedia {
  id        String    @id @default(cuid())
  schoolId  String    @map("school_id")
  orgId     String?   @map("org_id")
  type      String // image, video
  url       String
  caption   String?
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("school_media")
  @@schema("marketplace")
}

/// Facility/amenity tags for a school.
model SchoolFacility {
  id        String   @id @default(cuid())
  schoolId  String   @map("school_id")
  orgId     String?  @map("org_id")
  name      String
  category  String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("school_facilities")
  @@schema("marketplace")
}

/// Published fee ranges shown in discovery (not the CRM fee engine).
model SchoolFeeRange {
  id         String   @id @default(cuid())
  schoolId   String   @map("school_id")
  orgId      String?  @map("org_id")
  gradeLabel String   @map("grade_label")
  minAmount  Decimal  @map("min_amount") @db.Decimal(12, 2)
  maxAmount  Decimal  @map("max_amount") @db.Decimal(12, 2)
  frequency  String? // annual, monthly
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("school_fee_ranges")
  @@schema("marketplace")
}

/// Board/affiliation details for a school (e.g., CBSE, ICSE, State).
model SchoolAffiliation {
  id            String    @id @default(cuid())
  schoolId      String    @map("school_id")
  orgId         String?   @map("org_id")
  board         String
  affiliationNo String?   @map("affiliation_no")
  validTill     DateTime? @map("valid_till")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("school_affiliation")
  @@schema("marketplace")
}

/// Accreditations/awards/recognitions for a school.
model SchoolAccreditation {
  id        String    @id @default(cuid())
  schoolId  String    @map("school_id")
  orgId     String?   @map("org_id")
  name      String
  issuedBy  String?   @map("issued_by")
  issuedAt  DateTime? @map("issued_at")
  validTill DateTime? @map("valid_till")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("school_accreditation")
  @@schema("marketplace")
}

/// Weekly operating hours for a school (display + "open now" + ranking signal).
model SchoolHours {
  id        String   @id @default(cuid())
  schoolId  String   @map("school_id")
  orgId     String?  @map("org_id")
  dayOfWeek Int      @map("day_of_week") // 0=Sun .. 6=Sat
  openTime  String?  @map("open_time") // HH:mm
  closeTime String?  @map("close_time") // HH:mm
  isClosed  Boolean  @default(false) @map("is_closed")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, dayOfWeek])
  @@index([schoolId])
  @@map("school_hours")
  @@schema("marketplace")
}

model Instructor {
  id              String   @id @default(cuid())
  orgId           String   @map("org_id")
  schoolId        String   @map("school_id")
  name            String
  qualification   String?
  specialization  String?
  experienceYears Int?     @map("experience_years")
  photoUrl        String?  @map("photo_url")
  bio             String?
  isActive        Boolean  @default(true) @map("is_active")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([orgId])
  @@map("instructors")
  @@schema("marketplace")
}

model BatchSchedule {
  id              String    @id @default(cuid())
  orgId           String    @map("org_id")
  schoolId        String    @map("school_id")
  activityName    String    @map("activity_name")
  batchName       String?   @map("batch_name")
  daysOfWeek      String[]  @map("days_of_week")
  startTime       String    @map("start_time")
  endTime         String    @map("end_time")
  ageGroupMin     Int?      @map("age_group_min")
  ageGroupMax     Int?      @map("age_group_max")
  monthlyFee      Int       @default(0) @map("monthly_fee")
  yearlyFee       Int?      @map("yearly_fee")
  registrationFee Int       @default(0) @map("registration_fee")
  capacity        Int       @default(20)
  enrolledCount   Int       @default(0) @map("enrolled_count")
  gender          String    @default("ALL")
  isActive        Boolean   @default(true) @map("is_active")
  isFull          Boolean   @default(false) @map("is_full")
  startDate       DateTime? @map("start_date")
  endDate         DateTime? @map("end_date")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  school        School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  trialBookings TrialClassBooking[]

  @@index([schoolId])
  @@index([orgId])
  @@map("batch_schedules")
  @@schema("marketplace")
}

model TrialClassBooking {
  id              String    @id @default(cuid())
  orgId           String    @map("org_id")
  schoolId        String    @map("school_id")
  batchScheduleId String?   @map("batch_schedule_id")
  parentName      String    @map("parent_name")
  phone           String
  email           String?
  childName       String    @map("child_name")
  childAge        Int?      @map("child_age")
  preferredDate   DateTime? @map("preferred_date")
  activityType    String?   @map("activity_type")
  message         String?
  status          String    @default("PENDING")
  confirmedAt     DateTime? @map("confirmed_at")
  cancelledAt     DateTime? @map("cancelled_at")
  notes           String?
  ipAddress       String?   @map("ip_address")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  batchSchedule BatchSchedule? @relation(fields: [batchScheduleId], references: [id])

  @@index([schoolId])
  @@index([orgId])
  @@index([status])
  @@index([createdAt])
  @@map("trial_class_bookings")
  @@schema("marketplace")
}

/// Parent account (external actor; mobile-OTP first). Not tenant-scoped.
model Parent {
  id           String    @id @default(cuid())
  phone        String    @unique
  // Every phone this account has ever used — the fallback link that scopes a
  // parent to a Student (linkedStudentsWhere) matches on Student.guardianPhone
  // matching the CURRENT phone. Without this, changing your phone silently
  // drops a student whose school record still has the old number, unless an
  // explicit StudentGuardianLink (parentId-keyed) already covers it.
  phoneHistory String[]  @default([]) @map("phone_history")
  email        String?   @unique
  name         String?
  city         String?
  pinHash      String?   @map("pin_hash")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  kids            KidProfile[]
  enquiries       ParentEnquiry[]
  applications    ParentApplication[]
  bookmarks       ParentBookmark[]
  reviews         SchoolReview[]
  waitlistEntries WaitlistEntry[]
  openDayRsvps    OpenDayRsvp[]
  guardianLinks   StudentGuardianLink[]
  userId          String?               @unique @map("user_id")
  user            User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone])
  @@map("parents")
  @@schema("marketplace")
}

/// A child belonging to a parent (used to pre-fill enquiries/applications).
model KidProfile {
  id          String    @id @default(cuid())
  parentId    String    @map("parent_id")
  name        String
  dateOfBirth DateTime? @map("date_of_birth")
  gender      Gender?
  gradeSought String?   @map("grade_sought")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  parent  Parent         @relation(fields: [parentId], references: [id], onDelete: Cascade)
  reviews SchoolReview[]

  @@index([parentId])
  @@map("kids_profiles")
  @@schema("marketplace")
}

/// Discovery-side enquiry from a parent to a school (becomes a CRM lead).
model ParentEnquiry {
  id             String        @id @default(cuid())
  orgId          String?       @map("org_id")
  schoolId       String        @map("school_id")
  parentId       String        @map("parent_id")
  kidName        String?       @map("kid_name")
  gradeSought    String?       @map("grade_sought")
  message        String?
  status         EnquiryStatus @default(NEW)
  leadId         String?       @map("lead_id") // soft link to crm.leads once created
  type           String?       @default("ENQUIRY") // ENQUIRY, VISIT_REQUEST
  preferredDate  DateTime?     @map("preferred_date")
  preferredTime  String?       @map("preferred_time")
  visitorCount   Int?          @map("visitor_count")
  lastFollowUpAt DateTime?     @map("last_follow_up_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  organization Organization? @relation(fields: [orgId], references: [id])
  school       School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  parent       Parent        @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([schoolId])
  @@index([parentId])
  @@index([status])
  @@map("parent_enquiries")
  @@schema("marketplace")
}

/// Formal admission application submitted by a parent and tracked by them.
model ParentApplication {
  id          String            @id @default(cuid())
  orgId       String?           @map("org_id")
  schoolId    String            @map("school_id")
  parentId    String            @map("parent_id")
  kidName     String            @map("kid_name")
  gradeSought String?           @map("grade_sought")
  status      ApplicationStatus @default(SUBMITTED)
  admissionId String?           @map("admission_id") // soft link to crm.admissions
  submittedAt DateTime          @default(now()) @map("submitted_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  deletedAt   DateTime?         @map("deleted_at")

  organization Organization? @relation(fields: [orgId], references: [id])
  school       School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  parent       Parent        @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([schoolId])
  @@index([parentId])
  @@index([status])
  @@map("parent_applications")
  @@schema("marketplace")
}

/// Parent's saved/bookmarked schools. Parent-owned; not tenant-scoped.
model ParentBookmark {
  id        String   @id @default(cuid())
  parentId  String   @map("parent_id")
  schoolId  String   @map("school_id")
  createdAt DateTime @default(now()) @map("created_at")

  parent Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([parentId, schoolId])
  @@index([schoolId])
  @@map("parent_bookmarks")
  @@schema("marketplace")
}

/// Profile view analytics (drives ranking + dashboards).
model SchoolView {
  id        String   @id @default(cuid())
  schoolId  String   @map("school_id")
  orgId     String?  @map("org_id")
  parentId  String?  @map("parent_id") // soft reference
  source    String?
  ipHash    String?  @map("ip_hash")
  createdAt DateTime @default(now()) @map("created_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([createdAt])
  @@map("school_views")
  @@schema("marketplace")
}

/// Parent review of a school (verified parents only; auto-publish).
model SchoolReview {
  id                   String       @id @default(cuid())
  schoolId             String       @map("school_id")
  orgId                String?      @map("org_id")
  parentId             String       @map("parent_id")
  rating               Int // 1-5 overall
  ratingAcademics      Int?         @map("rating_academics") // 1-5 (legacy SCHOOL columns; new reviews use subRatings)
  ratingFaculty        Int?         @map("rating_faculty") // 1-5
  ratingInfrastructure Int?         @map("rating_infrastructure") // 1-5
  ratingSafety         Int?         @map("rating_safety") // 1-5
  ratingActivities     Int?         @map("rating_activities") // 1-5
  ratingValue          Int?         @map("rating_value") // 1-5 value for money
  /// Institution-type-adaptive sub-ratings, keyed by category slug from
  /// src/lib/reviews/categories.ts (e.g. { "teaching": 5, "results": 4 }).
  subRatings           Json?        @map("sub_ratings")
  pros                 String[]     @default([]) // pros tags
  cons                 String[]     @default([]) // cons tags
  /// True when the reviewing parent has a confirmed admission at this school.
  isVerifiedAdmission  Boolean      @default(false) @map("is_verified_admission")
  /// Which child this review is about — enables per-kid reviews for the same
  /// school (Class 2 vs Class 9 are different experiences). Null = legacy.
  kidId                String?      @map("kid_id")
  /// Free-text class/course context shown on the card ("Class 2", "Piano").
  classOrCourse        String?      @map("class_or_course")
  title                String?
  body                 String?
  status               ReviewStatus @default(PUBLISHED)
  flagReason           String?      @map("flag_reason")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")
  deletedAt            DateTime?    @map("deleted_at")

  school       School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  organization Organization?    @relation(fields: [orgId], references: [id])
  parent       Parent           @relation(fields: [parentId], references: [id], onDelete: Cascade)
  kid          KidProfile?      @relation(fields: [kidId], references: [id])
  responses    ReviewResponse[]
  reports      ReviewReport[]

  @@index([schoolId])
  @@index([parentId])
  @@index([status])
  @@index([parentId, schoolId, kidId])
  @@map("school_reviews")
  @@schema("marketplace")
}

/// User-submitted report against a review; N distinct reports auto-flag it.
model ReviewReport {
  id               String   @id @default(cuid())
  reviewId         String   @map("review_id")
  reporterParentId String?  @map("reporter_parent_id") // null for anonymous/public reporter
  reporterKey      String?  @map("reporter_key") // ip/session hash for anonymous dedup
  reason           String?
  createdAt        DateTime @default(now()) @map("created_at")

  review SchoolReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([reviewId, reporterParentId])
  @@index([reviewId])
  @@map("review_reports")
  @@schema("marketplace")
}

/// Threaded responses to a review (school + parent reply chain).
model ReviewResponse {
  id         String    @id @default(cuid())
  reviewId   String    @map("review_id")
  orgId      String?   @map("org_id")
  authorType String    @map("author_type") // SCHOOL, PARENT, VIDHYAAN
  authorId   String?   @map("author_id") // soft reference
  body       String
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  review       SchoolReview  @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [orgId], references: [id])

  @@index([reviewId])
  @@map("review_responses")
  @@schema("marketplace")
}

/// Parent waitlist entry when a grade/seat is full.
model WaitlistEntry {
  id         String         @id @default(cuid())
  orgId      String         @map("org_id")
  schoolId   String         @map("school_id")
  parentId   String         @map("parent_id")
  gradeLabel String         @map("grade_label")
  position   Int?
  status     WaitlistStatus @default(WAITING)
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")
  deletedAt  DateTime?      @map("deleted_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  parent       Parent       @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([schoolId])
  @@index([status])
  @@map("waitlist_entries")
  @@schema("marketplace")
}

/// Public open-day / campus-visit event published by a school.
model OpenDayEvent {
  id          String    @id @default(cuid())
  orgId       String    @map("org_id")
  schoolId    String    @map("school_id")
  title       String
  description String?
  startsAt    DateTime  @map("starts_at")
  endsAt      DateTime? @map("ends_at")
  venue       String?
  capacity    Int?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  school       School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  rsvps        OpenDayRsvp[]

  @@index([orgId])
  @@index([schoolId])
  @@index([startsAt])
  @@map("open_day_events")
  @@schema("marketplace")
}

/// Parent RSVP to an open-day event. Parent-owned; not tenant-scoped.
model OpenDayRsvp {
  id        String     @id @default(cuid())
  eventId   String     @map("event_id")
  parentId  String     @map("parent_id")
  status    RsvpStatus @default(GOING)
  guests    Int        @default(1)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  event  OpenDayEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  parent Parent       @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([eventId, parentId])
  @@index([parentId])
  @@map("open_day_rsvp")
  @@schema("marketplace")
}

// ============================================================================
// SCHEMA: crm — school CRM product
// ============================================================================

/// Org-scoped academic/financial year; exactly one ACTIVE per org.
model AcademicYear {
  id        String             @id @default(cuid())
  orgId     String             @map("org_id")
  name      String // e.g., 2025-26
  type      AcademicYearType
  startDate DateTime           @map("start_date")
  endDate   DateTime           @map("end_date")
  status    AcademicYearStatus @default(UPCOMING)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  organization        Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  leads               Lead[]
  admissions          Admission[]
  admissionCapacities AdmissionCapacity[]
  students            Student[]
  studentBatches      StudentBatch[]
  feePlans            FeePlan[]
  invoices            Invoice[]
  payments            Payment[]
  events              Event[]
  campaigns           Campaign[]
  counsellorTargets   CounsellorTarget[]
  terms               Term[]
  forms               Form[]
  attendanceRecords   AttendanceRecord[]

  @@unique([orgId, name])
  @@index([orgId])
  @@index([status])
  @@map("academic_years")
  @@schema("crm")
}

/// Admission lead. Auto-created from Vidhyaan enquiries or manual entry.
model Lead {
  id               String       @id @default(cuid())
  orgId            String       @map("org_id")
  branchId         String?      @map("branch_id")
  academicYearId   String?      @map("academic_year_id")
  leadCode         String       @map("lead_code") // LD-YYYY-XXXXX
  parentName       String       @map("parent_name")
  phone            String
  email            String?
  kidName          String?      @map("kid_name")
  gradeSought      String?      @map("grade_sought")
  source           LeadSource   @default(OTHER)
  status           LeadStatus   @default(NEW)
  // Created past the org's free-tier leadCap. Blocks conversion to CONVERTED
  // while the org is still over cap (re-checked live, not just this flag —
  // see isOverLeadCap) — that's the actual monetization lever; everything
  // else about the lead stays fully manageable.
  queued           Boolean      @default(false)
  priority         LeadPriority @default(MEDIUM)
  assignedToId     String?      @map("assigned_to_id")
  enquiryId        String?      @map("enquiry_id") // soft link to marketplace.parent_enquiries
  lostReason       String?      @map("lost_reason")
  firstContactedAt DateTime?    @map("first_contacted_at") // drives response-rate metric
  nextFollowUpAt   DateTime?    @map("next_follow_up_at")
  createdById      String?      @map("created_by_id") // soft reference
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  deletedAt        DateTime?    @map("deleted_at")

  childAge         Int?      @map("child_age")
  currentSchool    String?   @map("current_school")
  expectedJoinDate DateTime? @map("expected_join_date")
  siblingInSchool  Boolean?  @default(false) @map("sibling_in_school")
  course           String?
  batch            String?
  studentAge       String?   @map("student_age")
  startDate        DateTime? @map("start_date")

  // Dedup / household identity
  phoneNormalized String? @map("phone_normalized") // cleanPhoneNumber(phone) — the dedup join key
  householdId     String? @map("household_id")

  organization Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch       Branch?        @relation(fields: [branchId], references: [id])
  academicYear AcademicYear?  @relation(fields: [academicYearId], references: [id])
  assignedTo   User?          @relation("LeadCounsellor", fields: [assignedToId], references: [id])
  household    Household?     @relation(fields: [householdId], references: [id])
  activities   LeadActivity[]
  admissions   Admission[]

  @@unique([orgId, leadCode])
  @@index([orgId, createdAt])
  @@index([orgId, status])
  @@index([orgId, assignedToId])
  @@index([orgId, phone])
  @@index([orgId, phoneNormalized])
  @@index([orgId, source, status])
  @@index([orgId, nextFollowUpAt])
  @@index([householdId])
  @@index([branchId])
  @@index([academicYearId])
  @@map("leads")
  @@schema("crm")
}

/// Timeline entry on a lead (notes, calls, status changes, etc.). Dependent child.
model LeadActivity {
  id             String       @id @default(cuid())
  orgId          String       @map("org_id")
  branchId       String?      @map("branch_id")
  academicYearId String?      @map("academic_year_id")
  leadId         String       @map("lead_id")
  type           ActivityType
  summary        String
  metadata       Json?
  performedById  String?      @map("performed_by_id") // soft reference
  createdAt      DateTime     @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([orgId, leadId, createdAt])
  @@index([type])
  @@map("lead_activities")
  @@schema("crm")
}

/// Org-defined custom field definitions for leads.
model LeadCustomField {
  id        String          @id @default(cuid())
  orgId     String          @map("org_id")
  label     String
  key       String
  type      CustomFieldType
  options   Json? // for DROPDOWN
  required  Boolean         @default(false)
  sortOrder Int             @default(0) @map("sort_order")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@unique([orgId, key])
  @@index([orgId])
  @@map("lead_custom_fields")
  @@schema("crm")
}

/// Admission record progressing through org-configurable pipeline stages.
model Admission {
  id              String          @id @default(cuid())
  orgId           String          @map("org_id")
  branchId        String?         @map("branch_id")
  academicYearId  String?         @map("academic_year_id")
  admissionCode   String          @map("admission_code") // ADM-YYYY-XXXXX
  leadId          String?         @map("lead_id")
  stageId         String?         @map("stage_id")
  status          AdmissionStatus @default(IN_PROGRESS)
  applicantName   String          @map("applicant_name")
  parentName      String?         @map("parent_name")
  gradeSought     String?         @map("grade_sought")
  phone           String?
  email           String?
  assignedToId    String?         @map("assigned_to_id")
  rejectionReason String?         @map("rejection_reason")
  decidedAt       DateTime?       @map("decided_at")
  createdById     String?         @map("created_by_id") // soft reference
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")
  /// Admitted records cannot be deleted (they anchor student records and
  /// reporting); archiving hides them from active views instead.
  archivedAt      DateTime?       @map("archived_at")

  // Dedup / household identity
  phoneNormalized String? @map("phone_normalized") // cleanPhoneNumber(phone) — the dedup join key
  householdId     String? @map("household_id")

  organization Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch       Branch?             @relation(fields: [branchId], references: [id])
  academicYear AcademicYear?       @relation(fields: [academicYearId], references: [id])
  lead         Lead?               @relation(fields: [leadId], references: [id])
  stage        AdmissionStage?     @relation(fields: [stageId], references: [id])
  assignedTo   User?               @relation("AdmissionCounsellor", fields: [assignedToId], references: [id])
  household    Household?          @relation(fields: [householdId], references: [id])
  activities   AdmissionActivity[]
  documents    AdmissionDocument[]
  student      Student?

  @@unique([orgId, admissionCode])
  @@index([orgId, createdAt])
  @@index([orgId, status])
  @@index([orgId, stageId])
  @@index([orgId, assignedToId])
  @@index([orgId, phoneNormalized])
  @@index([householdId])
  @@index([branchId])
  @@index([academicYearId])
  @@map("admissions")
  @@schema("crm")
}

/// Org-configurable pipeline stage (School default 8, LC default 4).
model AdmissionStage {
  id              String    @id @default(cuid())
  orgId           String    @map("org_id")
  name            String
  sortOrder       Int       @map("sort_order")
  isWon           Boolean   @default(false) @map("is_won")
  isLost          Boolean   @default(false) @map("is_lost")
  requiresDocs    Boolean   @default(false) @map("requires_docs")
  requiresPayment Boolean   @default(false) @map("requires_payment")
  color           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  admissions   Admission[]

  @@unique([orgId, sortOrder])
  @@index([orgId])
  @@map("admission_stages")
  @@schema("crm")
}

/// Timeline entry on an admission. Dependent child.
model AdmissionActivity {
  id             String       @id @default(cuid())
  orgId          String       @map("org_id")
  branchId       String?      @map("branch_id")
  academicYearId String?      @map("academic_year_id")
  admissionId    String       @map("admission_id")
  type           ActivityType
  summary        String
  metadata       Json?
  performedById  String?      @map("performed_by_id") // soft reference
  createdAt      DateTime     @default(now()) @map("created_at")

  admission Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)

  @@index([orgId, admissionId, createdAt])
  @@map("admission_activities")
  @@schema("crm")
}

/// Document uploaded against an admission (ClamAV + Vision scanned). Dependent child.
model AdmissionDocument {
  id           String               @id @default(cuid())
  orgId        String               @map("org_id")
  admissionId  String               @map("admission_id")
  name         String
  type         String // PDF, JPG, PNG
  url          String // Org/Student/filename in DO Spaces
  sizeBytes    Int?                 @map("size_bytes")
  scanStatus   DocumentReviewStatus @default(PENDING) @map("scan_status")
  isAadhaar    Boolean              @default(false) @map("is_aadhaar") // max 1yr retention
  expiresAt    DateTime?            @map("expires_at")
  uploadedById String?              @map("uploaded_by_id") // soft reference
  createdAt    DateTime             @default(now()) @map("created_at")
  deletedAt    DateTime?            @map("deleted_at")

  admission Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([admissionId])
  @@index([scanStatus])
  @@map("admission_documents")
  @@schema("crm")
}

/// Seat capacity per grade per year; drives auto-close + waitlist trigger.
model AdmissionCapacity {
  id             String   @id @default(cuid())
  orgId          String   @map("org_id")
  branchId       String?  @map("branch_id")
  academicYearId String   @map("academic_year_id")
  gradeLabel     String   @map("grade_label")
  totalSeats     Int      @map("total_seats")
  filledSeats    Int      @default(0) @map("filled_seats")
  autoClose      Boolean  @default(true) @map("auto_close")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  @@unique([orgId, academicYearId, branchId, gradeLabel])
  @@index([orgId])
  @@index([academicYearId])
  @@map("admission_capacity")
  @@schema("crm")
}

/// Reusable digital form definition (builder output). Entity-agnostic — a
/// submission is routed to Lead/Admission/Enquiry through target adapters
/// (src/lib/forms/targets), so the same engine serves schools, learning
/// centres, coaching centres, junior colleges, etc. `schema` holds the
/// sections/fields; `mapsTo` on each field is a CANONICAL key resolved by
/// the adapter, never a raw column.
model Form {
  id                   String      @id @default(cuid())
  orgId                String      @map("org_id")
  branchId             String?     @map("branch_id")
  academicYearId       String?     @map("academic_year_id")
  name                 String
  description          String?
  purpose              FormPurpose @default(ADMISSION)
  status               FormStatus  @default(DRAFT)
  version              Int         @default(1)
  isDefault            Boolean     @default(false) @map("is_default")
  slug                 String?
  /// sections[] -> fields[]; field { key,label,type,required,options,placeholder,validation,mapsTo }
  schema               Json
  /// builder settings: theme, consentText, successMessage, redirectUrl
  settings             Json?
  /// targeting — auto-select a form per course/grade (and campaign at send time)
  courseIds            String[]    @map("course_ids")
  gradeLabels          String[]    @map("grade_labels")
  /// optional in-form application fee
  applicationFeeAmount Decimal?    @map("application_fee_amount") @db.Decimal(10, 2)
  feeCurrency          String      @default("INR") @map("fee_currency")
  feeRequired          Boolean     @default(false) @map("fee_required")
  createdById          String?     @map("created_by_id") // soft reference
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")
  deletedAt            DateTime?   @map("deleted_at")

  organization Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch       Branch?          @relation(fields: [branchId], references: [id])
  academicYear AcademicYear?    @relation(fields: [academicYearId], references: [id])
  instances    FormInstance[]
  submissions  FormSubmission[]

  @@index([orgId, purpose, status])
  @@index([orgId, createdAt])
  @@index([branchId])
  @@index([academicYearId])
  @@map("forms")
  @@schema("crm")
}

/// One sent/shared link. Points at a polymorphic target via targetType +
/// targetId (soft ref — no FK, so no coupling to optional modules). Written
/// by the public /apply/[token] route via the base client (no session).
model FormInstance {
  id            String             @id @default(cuid())
  orgId         String             @map("org_id")
  formId        String             @map("form_id")
  /// what this instance feeds: ADMISSION | LEAD | ENQUIRY | STANDALONE
  targetType    FormPurpose        @map("target_type")
  targetId      String?            @map("target_id")
  campaignId    String?            @map("campaign_id")
  token         String             @unique
  status        FormInstanceStatus @default(SENT)
  channel       FormChannel        @default(LINK)
  sentToEmail   String?            @map("sent_to_email")
  sentToPhone   String?            @map("sent_to_phone")
  /// whitelisted prefill values keyed by field key
  prefill       Json?
  paymentStatus FormPaymentStatus  @default(NONE) @map("payment_status")
  /// gateway order id — never overwritten on payment.failed (billing invariant)
  gatewayRef    String?            @map("gateway_ref")
  expiresAt     DateTime?          @map("expires_at")
  openedAt      DateTime?          @map("opened_at")
  submittedAt   DateTime?          @map("submitted_at")
  createdById   String?            @map("created_by_id")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  form        Form             @relation(fields: [formId], references: [id], onDelete: Cascade)
  submissions FormSubmission[]

  @@index([orgId])
  @@index([formId])
  @@index([orgId, targetType, targetId])
  @@index([campaignId])
  @@map("form_instances")
  @@schema("crm")
}

/// Captured answers for one instance. Snapshots schemaVersion so later
/// template edits never corrupt historical submissions. Written by the
/// public route via the base client.
model FormSubmission {
  id            String            @id @default(cuid())
  orgId         String            @map("org_id")
  instanceId    String            @map("instance_id")
  formId        String            @map("form_id")
  targetType    FormPurpose       @map("target_type")
  targetId      String?           @map("target_id")
  campaignId    String?           @map("campaign_id")
  schemaVersion Int               @map("schema_version")
  /// answers keyed by field key
  data          Json
  /// uploaded document refs (post-scan)
  files         Json?
  /// per-field hybrid-apply state: applied vs pending counsellor accept
  fieldStates   Json?             @map("field_states")
  reviewStatus  FormReviewStatus  @default(PENDING) @map("review_status")
  paymentStatus FormPaymentStatus @default(NONE) @map("payment_status")
  reviewedById  String?           @map("reviewed_by_id")
  reviewedAt    DateTime?         @map("reviewed_at")
  submitterIp   String?           @map("submitter_ip")
  submittedAt   DateTime          @default(now()) @map("submitted_at")

  instance FormInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  form     Form         @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([instanceId])
  @@index([formId])
  @@index([orgId, reviewStatus])
  @@index([campaignId])
  @@map("form_submissions")
  @@schema("crm")
}

/// Enrolled student. Auto-created on admission/lead convert.
model Student {
  id                    String        @id @default(cuid())
  orgId                 String        @map("org_id")
  branchId              String?       @map("branch_id")
  academicYearId        String?       @map("academic_year_id")
  studentCode           String        @map("student_code") // STU-YYYY-XXXXX
  rollNumber            String?       @map("roll_number")
  section               String?
  admissionId           String?       @unique @map("admission_id")
  batchId               String?       @map("batch_id")
  name                  String
  gender                Gender?
  dateOfBirth           DateTime?     @map("date_of_birth")
  gradeLabel            String?       @map("grade_label")
  guardianName          String?       @map("guardian_name")
  guardianPhone         String?       @map("guardian_phone")
  guardianEmail         String?       @map("guardian_email")
  status                StudentStatus @default(ACTIVE)
  alumniSince           DateTime?     @map("alumni_since")
  portalAccessRevokedAt DateTime?     @map("portal_access_revoked_at") // alumni: removed 60 days after
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  deletedAt             DateTime?     @map("deleted_at")

  // Dedup / household identity (keyed on guardianPhone)
  phoneNormalized String? @map("phone_normalized") // cleanPhoneNumber(guardianPhone)
  householdId     String? @map("household_id")

  organization        Organization             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch              Branch?                  @relation(fields: [branchId], references: [id])
  academicYear        AcademicYear?            @relation(fields: [academicYearId], references: [id])
  admission           Admission?               @relation(fields: [admissionId], references: [id])
  batch               StudentBatch?            @relation(fields: [batchId], references: [id])
  household           Household?               @relation(fields: [householdId], references: [id])
  invoices            Invoice[]
  payments            Payment[]
  concessions         Concession[]
  siblingLinksA       SiblingLink[]            @relation("SiblingPrimary")
  siblingLinksB       SiblingLink[]            @relation("SiblingRelated")
  activities          StudentActivity[]
  courseEnrollments   CourseEnrollment[]
  ledgerEntries       LedgerEntry[]
  guardianLinks       StudentGuardianLink[]
  attendanceRecords   AttendanceRecord[]
  biometricIdentities BiometricIdentity[]
  leaveRequests       LeaveRequest[]
  examResults         ExamResult[]
  scheduleSlots       EnrollmentScheduleSlot[]

  @@unique([orgId, studentCode])
  @@index([orgId, createdAt])
  @@index([orgId, status])
  @@index([orgId, gradeLabel])
  @@index([orgId, gradeLabel, section])
  @@index([orgId, phoneNormalized])
  @@index([householdId])
  @@index([branchId])
  @@index([academicYearId])
  @@index([batchId])
  @@map("students")
  @@schema("crm")
}

/// Family/household identity — groups Leads, Admissions and Students that share
/// a guardian (keyed on the normalized phone). Powers dedup + sibling grouping.
model Household {
  id              String   @id @default(cuid())
  orgId           String   @map("org_id")
  phoneNormalized String   @map("phone_normalized") // cleanPhoneNumber() of the guardian phone
  primaryName     String?  @map("primary_name")
  primaryEmail    String?  @map("primary_email")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  leads        Lead[]
  admissions   Admission[]
  students     Student[]

  @@unique([orgId, phoneNormalized])
  @@index([orgId])
  @@map("households")
  @@schema("crm")
}

model StudentActivity {
  id            String       @id @default(cuid())
  studentId     String       @map("student_id")
  type          ActivityType
  summary       String
  note          String?
  performedById String?      @map("performed_by_id")
  createdAt     DateTime     @default(now()) @map("created_at")

  student     Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  performedBy User?   @relation(name: "StudentActivityPerformedBy", fields: [performedById], references: [id])

  @@index([studentId])
  @@index([performedById])
  @@map("student_activities")
  @@schema("crm")
}

/// Org-defined custom field definitions for students.
model StudentCustomField {
  id        String          @id @default(cuid())
  orgId     String          @map("org_id")
  label     String
  key       String
  type      CustomFieldType
  options   Json?
  required  Boolean         @default(false)
  sortOrder Int             @default(0) @map("sort_order")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@unique([orgId, key])
  @@index([orgId])
  @@map("student_custom_fields")
  @@schema("crm")
}

/// Batch/cohort grouping (primarily Learning Centers).
model StudentBatch {
  id                 String    @id @default(cuid())
  orgId              String    @map("org_id")
  branchId           String?   @map("branch_id")
  academicYearId     String?   @map("academic_year_id")
  courseId           String?   @map("course_id") // optional link to the course this batch runs
  name               String
  programme          String?
  daysOfWeek         String[]  @default([]) @map("days_of_week") // Mon..Sun
  startTime          String?   @map("start_time") // HH:mm
  endTime            String?   @map("end_time") // HH:mm
  // Explicit session length for the schedule module (30/45/60/custom). Falls
  // back to the startTime/endTime diff, then 60, when null — see
  // src/lib/schedule/materialize.ts effectiveDurationMin().
  sessionDurationMin Int?      @map("session_duration_min")
  startDate          DateTime? @map("start_date")
  endDate            DateTime? @map("end_date")
  capacity           Int?
  isActive           Boolean   @default(true) @map("is_active")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  organization       Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch             Branch?             @relation(fields: [branchId], references: [id])
  academicYear       AcademicYear?       @relation(fields: [academicYearId], references: [id])
  course             Course?             @relation(fields: [courseId], references: [id])
  students           Student[]
  attendanceSessions AttendanceSession[]
  teacherAssignments TeacherAssignment[]
  courseSessions     CourseSession[]

  @@index([orgId])
  @@index([branchId])
  @@map("student_batches")
  @@schema("crm")
}

/// Links two students as siblings (drives sibling concessions/insights).
model SiblingLink {
  id        String   @id @default(cuid())
  orgId     String   @map("org_id")
  studentId String   @map("student_id")
  siblingId String   @map("sibling_id")
  relation  String? // brother, sister
  createdAt DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  student      Student      @relation("SiblingPrimary", fields: [studentId], references: [id], onDelete: Cascade)
  sibling      Student      @relation("SiblingRelated", fields: [siblingId], references: [id], onDelete: Cascade)

  @@unique([studentId, siblingId])
  @@index([orgId])
  @@index([siblingId])
  @@map("sibling_links")
  @@schema("crm")
}

/// Reusable fee structure template (org-level).
model FeePlanTemplate {
  id              String    @id @default(cuid())
  orgId           String    @map("org_id")
  name            String
  gradeLabel      String?   @map("grade_label")
  courseId        String?   @map("course_id")
  institutionType String?   @map("institution_type")
  structure       Json // array of { head, amount, frequency }
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  course       Course?      @relation(fields: [courseId], references: [id])
  feePlans     FeePlan[]

  @@index([orgId])
  @@index([courseId])
  @@map("fee_plan_templates")
  @@schema("crm")
}

/// Applied fee plan instance (per grade/batch/year), basis for invoices.
