// ============================================================================
// SCHEMA: platform — Vidhyaan core management
// ============================================================================

/// Tenant root. One row per customer organization (school / learning center).
model Organization {
  id                String          @id @default(cuid())
  name              String
  slug              String          @unique
  institutionType   InstitutionType @map("institution_type")
  email             String
  phone             String
  gstNumber         String?         @map("gst_number")
  status            OrgStatus       @default(PENDING_VERIFICATION)
  trialEndsAt       DateTime?       @map("trial_ends_at")
  trialReminderSent DateTime?       @map("trial_reminder_sent")
  leadCap           Int             @default(10) @map("lead_cap") // free-plan cap, configurable by super admin
  planId            String?         @map("plan_id")
  settings          Json? // institution-type adaptive config, prefixes, thresholds
  onboardedAt       DateTime?       @map("onboarded_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  deletedAt         DateTime?       @map("deleted_at")
  centerCategory    String?         @map("center_category")
  isDummy           Boolean         @default(false) @map("is_dummy")

  plan                  Plan?                     @relation(fields: [planId], references: [id])
  branches              Branch[]
  users                 User[]
  roleAssignments       UserRoleAssignment[]
  organizationModules   OrganizationModule[]
  auditLogs             AuditLog[]
  apiKeys               ApiKey[]
  domains               OrgDomain[]
  notificationQueue     NotificationQueue[]
  subscriptions         Subscription[]
  transactions          Transaction[]
  schools               School[]
  parentEnquiries       ParentEnquiry[]
  parentApplications    ParentApplication[]
  waitlistEntries       WaitlistEntry[]
  openDayEvents         OpenDayEvent[]
  schoolReviews         SchoolReview[]
  reviewResponses       ReviewResponse[]
  academicYears         AcademicYear[]
  leads                 Lead[]
  admissions            Admission[]
  admissionStages       AdmissionStage[]
  admissionCapacities   AdmissionCapacity[]
  students              Student[]
  households            Household[]
  studentBatches        StudentBatch[]
  siblingLinks          SiblingLink[]
  feePlans              FeePlan[]
  feePlanTemplates      FeePlanTemplate[]
  invoices              Invoice[]
  payments              Payment[]
  concessions           Concession[]
  events                Event[]
  emailTemplates        OrgEmailTemplate[]
  campaigns             Campaign[]
  notifications         Notification[]
  notificationPrefs     NotificationPreference[]
  counsellorTargets     CounsellorTarget[]
  communicationLogs     CommunicationLog[]
  terms                 Term[]
  courses               Course[]
  courseEnrollments     CourseEnrollment[]
  whatsappTemplates     WhatsappTemplate[]
  paymentGatewayConfigs PaymentGatewayConfig[]
  gatewayOrders         GatewayOrder[]
  refunds               Refund[]
  guardianLinks         StudentGuardianLink[]
  ledgerEntries         LedgerEntry[]
  messageWallets        MessageWallet[]
  messageSpendIntents   MessageSpendIntent[]
  messagingProviders    MessagingProviderConfig[]
  forms                 Form[]
  attendanceRecords     AttendanceRecord[]
  attendanceSessions    AttendanceSession[]
  teacherAssignments    TeacherAssignment[]
  courseSessions        CourseSession[]
  scheduleSlots         EnrollmentScheduleSlot[]
  timetableExceptions   TimetableException[]
  holidays              Holiday[]
  biometricDevices      BiometricDevice[]
  biometricIdentities   BiometricIdentity[]
  schoolClasses         SchoolClass[]
  classSections         ClassSection[]
  timetableSlots        TimetableSlot[]
  leaveRequests         LeaveRequest[]
  examResults           ExamResult[]

  @@index([status])
  @@index([institutionType])
  @@index([planId])
  @@map("organizations")
  @@schema("platform")
}

/// Physical/operational branch. Every org auto-gets one default branch.
model Branch {
  id          String    @id @default(cuid())
  orgId       String    @map("org_id")
  name        String
  isDefault   Boolean   @default(false) @map("is_default")
  code        String?
  addressLine String?   @map("address_line")
  city        String?
  state       String?
  pincode     String?
  phone       String?
  email       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  organization        Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userBranchAccess    UserBranchAccess[]
  leads               Lead[]
  admissions          Admission[]
  admissionCapacities AdmissionCapacity[]
  students            Student[]
  studentBatches      StudentBatch[]
  feePlans            FeePlan[]
  invoices            Invoice[]
  payments            Payment[]
  events              Event[]
  campaigns           Campaign[]
  counsellorTargets   CounsellorTarget[]
  forms               Form[]
  schoolClasses       SchoolClass[]

  @@index([orgId])
  @@map("branches")
  @@schema("platform")
}

/// All authenticated actors (platform staff + org staff + parents-as-users).
model User {
  id          String     @id @default(cuid())
  orgId       String?    @map("org_id") // null for platform-level users (SUPER_ADMIN etc.)
  email       String?    @unique
  phone       String?    @unique
  name        String
  status      UserStatus @default(ACTIVE)
  pinHash     String?    @map("pin_hash") // optional PIN for trusted devices
  pinSetAt    DateTime?  @map("pin_set_at")
  lastLoginAt DateTime?  @map("last_login_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")

  organization       Organization?            @relation(fields: [orgId], references: [id])
  branchAccess       UserBranchAccess[]
  roleAssignments    UserRoleAssignment[]
  assignedLeads      Lead[]                   @relation("LeadCounsellor")
  assignedAdmissions Admission[]              @relation("AdmissionCounsellor")
  counsellorTargets  CounsellorTarget[]
  communicationLogs  CommunicationLog[]
  notificationPrefs  NotificationPreference[]
  parent             Parent?
  studentActivities  StudentActivity[]        @relation("StudentActivityPerformedBy")
  twoFactor          UserTwoFactor?
  attendanceMarked   AttendanceRecord[]       @relation("AttendanceMarkedBy")
  teacherAssignments TeacherAssignment[]      @relation("TeacherAssignments")
  timetableSlots     TimetableSlot[]          @relation("TimetableTeacher")
  oauthAccounts      UserOAuthAccount[]
  mobileDevices      MobileDevice[]

  @@unique([orgId, email])
  @@index([orgId])
  @@index([phone])
  @@map("users")
  @@schema("platform")
}

/// Per-branch access grant; a user may hold a different role per branch.
model UserBranchAccess {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  branchId  String   @map("branch_id")
  role      UserRole
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([branchId])
  @@map("user_branch_access")
  @@schema("platform")
}

/// Global catalog of CRM feature modules (one row per module slug).
model Module {
  id          String   @id @default(cuid())
  slug        String   @unique // lead_management, admission_management, ...
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organizationModules OrganizationModule[]

  @@map("modules")
  @@schema("platform")
}

/// Per-org enablement of a module, toggled by Vidhyaan super admin.
model OrganizationModule {
  id         String    @id @default(cuid())
  orgId      String    @map("org_id")
  moduleId   String    @map("module_id")
  enabled    Boolean   @default(false)
  config     Json? // per-module limits/config (e.g., lead cap override)
  enabledAt  DateTime? @map("enabled_at")
  disabledAt DateTime? @map("disabled_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  module       Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([orgId, moduleId])
  @@index([orgId])
  @@map("organization_modules")
  @@schema("platform")
}

/// Append-only audit trail (3-5 year retention).
model AuditLog {
  id         String      @id @default(cuid())
  orgId      String?     @map("org_id")
  userId     String?     @map("user_id") // soft reference
  action     AuditAction
  entityType String      @map("entity_type")
  entityId   String?     @map("entity_id")
  before     Json?
  after      Json?
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  createdAt  DateTime    @default(now()) @map("created_at")

  organization Organization? @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
  @@schema("platform")
}

/// Logs from the school-data scraping/ingestion pipeline.
model ScrapingLog {
  id         String         @id @default(cuid())
  source     String
  targetUrl  String?        @map("target_url")
  schoolId   String?        @map("school_id") // soft reference into marketplace.schools
  status     ScrapingStatus @default(PENDING)
  recordsIn  Int            @default(0) @map("records_in")
  recordsOut Int            @default(0) @map("records_out")
  error      String?
  payload    Json?
  createdAt  DateTime       @default(now()) @map("created_at")

  @@index([status])
  @@index([schoolId])
  @@index([createdAt])
  @@map("scraping_logs")
  @@schema("platform")
}

/// API key for the public read-only API (gated by api_access). Max 3 active/org.
model ApiKey {
  id          String    @id @default(cuid())
  orgId       String    @map("org_id")
  name        String
  prefix      String // display hint, e.g. vk_live_ab12
  hash        String    @unique // sha256(token)
  ipWhitelist String[]  @default([]) @map("ip_whitelist")
  lastUsedAt  DateTime? @map("last_used_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([hash])
  @@map("api_keys")
  @@schema("platform")
}

/// Issued OTP record (hash only). Backs verification, brute-force lock + audit.
model OtpCode {
  id         String     @id @default(cuid())
  identifier String // phone or email
  channel    OtpChannel
  purpose    OtpPurpose
  codeHash   String     @map("code_hash")
  attempts   Int        @default(0)
  consumedAt DateTime?  @map("consumed_at")
  expiresAt  DateTime   @map("expires_at")
  ipAddress  String?    @map("ip_address")
  createdAt  DateTime   @default(now()) @map("created_at")

  @@index([identifier])
  @@index([expiresAt])
  @@map("otp_codes")
  @@schema("platform")
}

// Second-factor enrolment, one row per user. Primary factor (PIN/OTP) is
// verified first; this gates issuing the session. TOTP secret is stored
// encrypted via the payment vault (AES-256-GCM); SMS fallback rides the
// existing OtpCode table with purpose = MFA.
model UserTwoFactor {
  id           String          @id @default(cuid())
  userId       String          @unique @map("user_id")
  method       TwoFactorMethod @default(TOTP)
  secretEnc    String?         @map("secret_enc") // encrypted TOTP secret; null for SMS-only
  enabledAt    DateTime?       @map("enabled_at") // null until enrolment confirmed
  backupCodes  Json            @default("[]") // bcrypt hashes, single-use
  lastUsedStep Int?            @map("last_used_step") // anti-replay: reject reused TOTP window
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_two_factor")
  @@schema("platform")
}

enum TwoFactorMethod {
  TOTP
  SMS

  @@schema("platform")
}

/// External identity linked to a platform user (Google SSO for parents).
/// Separate table (not a column on User) so more providers can slot in later.
model UserOAuthAccount {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  provider          String // 'google'
  providerAccountId String   @map("provider_account_id") // Google `sub`
  email             String? // provider email at link time — display only
  createdAt         DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@unique([userId, provider])
  @@map("user_oauth_accounts")
  @@schema("platform")
}

/// Custom domain mapping for an org (custom_domain module).
model OrgDomain {
  id         String       @id @default(cuid())
  orgId      String       @map("org_id")
  domain     String       @unique
  status     DomainStatus @default(PENDING)
  dnsRecords Json?        @map("dns_records")
  verifiedAt DateTime?    @map("verified_at")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("org_domains")
  @@schema("platform")
}

model LocationCache {
  id          String   @id @default(cuid())
  latRounded  String   @map("lat_rounded")
  lngRounded  String   @map("lng_rounded")
  city        String
  state       String?
  country     String   @default("India")
  pincode     String?
  fullAddress String?  @map("full_address")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([latRounded, lngRounded])
  @@index([city])
  @@map("location_cache")
  @@schema("platform")
}

