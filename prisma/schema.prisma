// ============================================================================
// VIDHYAAN — Prisma Schema
// TechParrot Innovations LLP
// Single PostgreSQL database (Neon.tech) with 4 strictly-separated schemas.
// ----------------------------------------------------------------------------
// ARCHITECTURE NOTES / DECISIONS (flagged for confirmation):
//
// 1. `plans` was listed in the spec under BOTH the `platform` and `billing`
//    schemas. A plan catalog is a billing concern, so it is modeled ONCE in
//    the `billing` schema and referenced from `platform.organizations`.
//    -> Confirm: remove duplicate from platform. (No platform.plans created.)
//
// 2. The rule "every marketplace/CRM table has org_id" is applied to
//    ORG-OWNED data. It is intentionally NOT applied to externally-owned
//    parent data (`parents`, `kids_profiles`, `parent_bookmarks`,
//    `open_day_rsvp`) — a parent is a platform-wide actor, not a tenant child.
//
// 3. Tenancy columns (org_id / branch_id / academic_year_id) are modeled as
//    enforced relations on PRIMARY entities (leads, admissions, students,
//    invoices, etc.) and as indexed SCALAR columns on DEPENDENT CHILD tables
//    (lead_activities, invoice_items, ...) which are already tenant-scoped
//    through their parent. This honors "org_id on all tables" while keeping
//    the hub models (Organization/Branch/AcademicYear) tractable.
//
// 4. created_by / updated_by are modeled as indexed scalar columns (soft
//    references to users.id), not FK relations, to avoid an unmanageable
//    number of back-relations on the User model.
//
// 5. Soft delete: `deleted_at` on all major tables. Hard purge after 30 days
//    is handled by a scheduled job, not the schema.
// ============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["platform", "marketplace", "crm", "billing"]
}

