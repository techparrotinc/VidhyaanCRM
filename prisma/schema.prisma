/// Student fee invoice (INV-YYYY-XXXXX).
model Invoice {
  id             String        @id @default(cuid())
  orgId          String        @map("org_id")
  branchId       String?       @map("branch_id")
  academicYearId String?       @map("academic_year_id")
  invoiceNumber  String        @map("invoice_number") // INV-YYYY-XXXXX
  studentId      String        @map("student_id")
  totalAmount    Decimal       @map("total_amount") @db.Decimal(12, 2)
  paidAmount     Decimal       @default(0) @map("paid_amount") @db.Decimal(12, 2)
  lateFeeAmount  Decimal       @default(0) @map("late_fee_amount") @db.Decimal(12, 2)
  status         InvoiceStatus @default(UNPAID)
  invoiceType    InvoiceType   @default(ADHOC) @map("invoice_type")
  termId         String?       @map("term_id")
  courseId       String?       @map("course_id")
  dueDate        DateTime?     @map("due_date")
  scheduledDate  DateTime?     @map("scheduled_date")
  batchId        String?       @map("batch_id")
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  organization  Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch        Branch?        @relation(fields: [branchId], references: [id])
  academicYear  AcademicYear?  @relation(fields: [academicYearId], references: [id])
  student       Student        @relation(fields: [studentId], references: [id])
  term          Term?          @relation(fields: [termId], references: [id])
  course        Course?        @relation(fields: [courseId], references: [id])
  items         InvoiceItem[]
  payments      Payment[]
  concessions   Concession[]
  gatewayOrders GatewayOrder[]

  @@unique([orgId, invoiceNumber])
  @@index([orgId, createdAt])
  @@index([orgId, status])
  @@index([orgId, studentId])
  @@index([orgId, dueDate])
  @@index([orgId, status, dueDate])
  @@index([orgId, invoiceType])
  @@index([termId])
  @@index([courseId])
  @@index([batchId])
  @@map("invoices")
  @@schema("crm")
}

/// Line item on an invoice. Dependent child.
model InvoiceItem {
  id        String   @id @default(cuid())
  orgId     String   @map("org_id")
  invoiceId String   @map("invoice_id")
  head      String // fee head name
  amount    Decimal  @db.Decimal(12, 2)
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([invoiceId])
  @@map("invoice_items")
  @@schema("crm")
}

/// Payment against an invoice (RCP-YYYY-XXXXX); partial payments allowed.
model Payment {
  id             String        @id @default(cuid())
  orgId          String        @map("org_id")
  branchId       String?       @map("branch_id")
  academicYearId String?       @map("academic_year_id")
  receiptNumber  String        @map("receipt_number") // RCP-YYYY-XXXXX
  invoiceId      String        @map("invoice_id")
  studentId      String?       @map("student_id")
  amount         Decimal       @db.Decimal(12, 2)
  method         PaymentMethod @default(RAZORPAY)
  status         PaymentStatus @default(PENDING)
  gatewayRef     String?       @map("gateway_ref") // Razorpay payment id
  gatewayOrderId String?       @map("gateway_order_id") // soft reference → billing.gateway_orders
  refundedAmount Decimal       @default(0) @map("refunded_amount") @db.Decimal(12, 2)
  instrumentNo   String?       @map("instrument_no") // cheque / DD number
  instrumentDate DateTime?     @map("instrument_date")
  bankName       String?       @map("bank_name")
  bankBranch     String?       @map("bank_branch")
  utrNumber      String?       @map("utr_number") // NEFT/RTGS/IMPS UTR
  clearedAt      DateTime?     @map("cleared_at") // cheque/DD/NEFT realization
  paidAt         DateTime?     @map("paid_at")
  createdById    String?       @map("created_by_id") // soft reference
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch       Branch?       @relation(fields: [branchId], references: [id])
  academicYear AcademicYear? @relation(fields: [academicYearId], references: [id])
  invoice      Invoice       @relation(fields: [invoiceId], references: [id])
  student      Student?      @relation(fields: [studentId], references: [id])
  refunds      Refund[]

  @@unique([orgId, receiptNumber])
  @@index([orgId, gatewayOrderId])
  @@index([orgId, paidAt])
  @@index([orgId, status])
  @@index([orgId, invoiceId])
  @@index([orgId, studentId])
  @@map("payments")
  @@schema("crm")
}

/// Manual fee concession/discount applied by school admin.
model Concession {
  id           String         @id @default(cuid())
  orgId        String         @map("org_id")
  studentId    String?        @map("student_id")
  invoiceId    String?        @map("invoice_id")
  type         ConcessionType
  value        Decimal        @db.Decimal(12, 2)
  reason       String?
  approvedById String?        @map("approved_by_id") // soft reference
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  deletedAt    DateTime?      @map("deleted_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  student      Student?     @relation(fields: [studentId], references: [id])
  invoice      Invoice?     @relation(fields: [invoiceId], references: [id])

  @@index([orgId])
  @@index([studentId])
  @@index([invoiceId])
  @@map("concessions")
  @@schema("crm")
}

/// Internal CRM event (calendar/meeting); distinct from public open days.
model Event {
  id              String      @id @default(cuid())
  orgId           String      @map("org_id")
  branchId        String?     @map("branch_id")
  academicYearId  String?     @map("academic_year_id")
  title           String
  description     String?
  type            String? // OPEN_HOUSE, PTM, ANNUAL_DAY... / DEMO_CLASS, WORKSHOP... (institution-specific labels)
  capacity        Int?
  status          EventStatus @default(DRAFT) // DRAFT editable; PUBLISHED locked (cancel only)
  isPublished     Boolean     @default(false) @map("is_published") // deprecated by status; kept until phase 2 decides marketplace flag
  startsAt        DateTime    @map("starts_at")
  endsAt          DateTime?   @map("ends_at")
  location        String?
  meetingLink     String?     @map("meeting_link") // manual Zoom link Phase 1
  imageUrl        String?     @map("image_url") // S3 cover image
  publishedAt     DateTime?   @map("published_at")
  // Exclusive claim held for the duration of an Announce send — the send
  // loop makes many slow external calls (email/SMS/WhatsApp per recipient),
  // too long to hold inside a DB transaction/advisory lock. Without this,
  // two concurrent Announce POSTs both pass the PUBLISHED check and both run
  // the full send loop: double credit charges, double-spammed parents,
  // duplicate EventAnnouncement audit rows. Cleared after the send completes
  // (success or failure); a claim older than the staleness window is
  // reclaimable in case a process crashed mid-send.
  announcingSince DateTime?   @map("announcing_since")
  audience        String? // ALL | PARENTS | LEADS (announce default)
  createdById     String?     @map("created_by_id") // soft reference
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  deletedAt       DateTime?   @map("deleted_at")

  organization  Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch        Branch?             @relation(fields: [branchId], references: [id])
  academicYear  AcademicYear?       @relation(fields: [academicYearId], references: [id])
  rsvps         EventRsvp[]
  announcements EventAnnouncement[]

  @@index([orgId])
  @@index([startsAt])
  @@index([orgId, startsAt])
  @@map("events")
  @@schema("crm")
}

/// RSVP to an internal CRM event. Dependent child.
model EventRsvp {
  id           String     @id @default(cuid())
  orgId        String     @map("org_id")
  eventId      String     @map("event_id")
  attendeeType String     @map("attendee_type") // USER, PARENT, LEAD
  attendeeId   String?    @map("attendee_id") // soft reference
  status       RsvpStatus @default(GOING)
  createdAt    DateTime   @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([eventId])
  @@map("event_rsvp")
  @@schema("crm")
}

/// Org override of a system email template (subject/body). Absence of a
/// row = the code default in src/lib/mail/org-templates.ts applies.
model OrgEmailTemplate {
  id        String   @id @default(cuid())
  orgId     String   @map("org_id")
  key       String // FEE_INVOICE, EVENT_INVITE, EVENT_CANCELLED, ENQUIRY_CONFIRMATION
  subject   String
  body      String // plain text with {{variables}}; rendered into branded shell
  updatedBy String?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, key])
  @@map("org_email_templates")
  @@schema("crm")
}

/// Audit of an event being announced through channels on publish.
model EventAnnouncement {
  id             String   @id @default(cuid())
  orgId          String   @map("org_id")
  eventId        String   @map("event_id")
  channels       String[] // PORTAL, EMAIL, WHATSAPP, SMS
  audience       String // ALL | PARENTS | LEADS
  recipientCount Int      @default(0) @map("recipient_count")
  sentCount      Int      @default(0) @map("sent_count")
  failedCount    Int      @default(0) @map("failed_count")
  createdById    String?  @map("created_by_id")
  createdAt      DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([eventId])
  @@map("event_announcements")
  @@schema("crm")
}

/// Bulk outreach campaign (Email/SMS/WhatsApp via MSG91/Resend).
model Campaign {
  id                 String          @id @default(cuid())
  orgId              String          @map("org_id")
  branchId           String?         @map("branch_id")
  academicYearId     String?         @map("academic_year_id")
  name               String
  channel            CampaignChannel
  status             CampaignStatus  @default(DRAFT)
  templateBody       String?         @map("template_body")
  /// Soft ref to crm.whatsapp_templates — chosen approved template for
  /// WHATSAPP campaigns (send builds positional params from it)
  whatsappTemplateId String?         @map("whatsapp_template_id")
  /// Soft ref to crm.forms — when set, each recipient gets a unique digital
  /// form link (per-recipient FormInstance token) injected as {{link}}.
  formTemplateId     String?         @map("form_template_id")
  /// Custom token values typed at compose time (e.g. holiday reason /
  /// resume date) — merged over the auto-filled campaign variables.
  paramValues        Json?           @map("param_values")
  scheduledAt        DateTime?       @map("scheduled_at")
  sentAt             DateTime?       @map("sent_at")
  audienceFilter     Json?           @map("audience_filter")
  stats              Json?
  /// Optional external spend (ads/print) for ROI reporting — captured on the
  /// Campaign Effectiveness report, not during send.
  costAmount         Decimal?        @map("cost_amount") @db.Decimal(12, 2)
  createdById        String?         @map("created_by_id")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  deletedAt          DateTime?       @map("deleted_at")

  organization Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch       Branch?             @relation(fields: [branchId], references: [id])
  academicYear AcademicYear?       @relation(fields: [academicYearId], references: [id])
  recipients   CampaignRecipient[]

  @@index([orgId])
  @@index([status])
  @@map("campaigns")
  @@schema("crm")
}

model CampaignRecipient {
  id                String             @id @default(cuid())
  orgId             String             @map("org_id")
  campaignId        String             @map("campaign_id")
  recipientType     String             @map("recipient_type")
  recipientId       String?            @map("recipient_id")
  name              String?
  phone             String?
  email             String?
  status            CampaignSendStatus @default(PENDING)
  sentAt            DateTime?          @map("sent_at")
  deliveredAt       DateTime?          @map("delivered_at")
  readAt            DateTime?          @map("read_at")
  failureReason     String?            @map("failure_reason")
  /// Meta wamid — joins delivery webhooks back to this recipient
  providerMessageId String?            @map("provider_message_id")
  createdAt         DateTime           @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([campaignId])
  @@index([providerMessageId])
  @@map("campaign_recipients")
  @@schema("crm")
}

/// Outbound WhatsApp message log (Meta Cloud API sends). One row per send;
/// the delivery webhook updates status by wamid. `ref` mirrors the credit
/// ledger reference (fee_invoice:<id>, campaign_recipient:<id>, …).
model WhatsappMessage {
  id           String   @id @default(cuid())
  orgId        String   @map("org_id")
  wamid        String?  @unique
  phone        String
  templateName String   @map("template_name")
  ref          String?
  status       String   @default("ACCEPTED") // ACCEPTED/SENT/DELIVERED/READ/FAILED
  error        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([orgId, createdAt])
  @@index([phone])
  @@map("whatsapp_messages")
  @@schema("crm")
}

/// DLT-approved WhatsApp templates saved by org admin.
model WhatsappTemplate {
  id               String           @id @default(cuid())
  orgId            String           @map("org_id")
  name             String
  msg91TemplateId  String           @map("msg91_template_id")
  body             String
  /// Meta language code of the approved template
  language         String           @default("en")
  /// Ordered variable tokens mapping to {{1}}..{{n}} in the approved
  /// template, e.g. ["parentName","amount"]. null = legacy
  /// single-blob-parameter mode.
  variables        Json?
  /// Functional bucket (GENERAL/FEE_REMINDER/ATTENDANCE/HOMEWORK/…) — see
  /// src/constants/whatsapp-template-categories.ts
  category         String           @default("GENERAL")
  /// Meta pricing category (MARKETING/UTILITY/AUTHENTICATION) — drives
  /// per-message credit cost (marketing costs Meta ~7.5× utility)
  metaCategory     String?          @map("meta_category")
  /// Which WhatsApp account this template lives on
  accountScope     WaAccountScope   @default(VIDHYAAN) @map("account_scope")
  /// Soft ref to billing.messaging_provider_configs when accountScope=OWN
  providerConfigId String?          @map("provider_config_id")
  status           WaTemplateStatus @default(DRAFT)
  /// Soft ref to platform.shared_whatsapp_templates when copied from catalog
  sharedTemplateId String?          @map("shared_template_id")
  createdById      String?          @map("created_by_id")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  deletedAt        DateTime?        @map("deleted_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([sharedTemplateId])
  @@map("whatsapp_templates")
  @@schema("crm")
}

enum WaAccountScope {
  VIDHYAAN
  OWN

  @@schema("crm")
}

enum WaTemplateStatus {
  DRAFT
  VERIFIED
  SYNCED

  @@schema("crm")
}

/// Platform-managed catalog of templates approved on Vidhyaan's shared
/// WhatsApp Business account. Orgs on the Vidhyaan account copy entries
/// from here instead of hand-typing MSG91 template names.
model SharedWhatsappTemplate {
