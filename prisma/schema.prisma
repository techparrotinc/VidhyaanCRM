  @@schema("crm")
}

// ============================================================================
// SCHEMA: billing — subscriptions and revenue
// ============================================================================

/// Subscription plan catalog (canonical; referenced by platform.organizations).
model Plan {
  id             String    @id @default(cuid())
  slug           String    @unique // free, growth, pro, enterprise
  name           String
  description    String?
  monthlyPrice   Decimal   @map("monthly_price") @db.Decimal(12, 2)
  quarterlyPrice Decimal?  @map("quarterly_price") @db.Decimal(12, 2)
  annualPrice    Decimal?  @map("annual_price") @db.Decimal(12, 2)
  leadCap        Int?      @map("lead_cap") // null = unlimited
  isPublic       Boolean   @default(true) @map("is_public")
  isActive       Boolean   @default(true) @map("is_active")
  sortOrder      Int       @default(0) @map("sort_order")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organizations Organization[]
  planModules   PlanModule[]
  planPrices    PlanPrice[]
  subscriptions Subscription[]

  @@map("plans")
  @@schema("billing")
}

enum StudentSlab {
  S50 // up to 50 students
  S100 // 51–100
  S200 // 101–200
  S500 // 201–500
  S500_PLUS // 500+ ("starting at"; overage per student, custom quote above 1000)

  @@schema("billing")
}

/// Student-slab pricing for a plan (list + optional launch-offer price).
model PlanPrice {
  id                String      @id @default(cuid())
  planId            String      @map("plan_id")
  slab              StudentSlab
  monthlyPrice      Decimal     @map("monthly_price") @db.Decimal(12, 2)
  annualPrice       Decimal     @map("annual_price") @db.Decimal(12, 2)
  launchMonthly     Decimal?    @map("launch_monthly") @db.Decimal(12, 2)
  launchEndsAt      DateTime?   @map("launch_ends_at") // launch price valid until; null = no expiry
  bundledAiCredits  Int         @default(0) @map("bundled_ai_credits")
  overagePerStudent Decimal?    @map("overage_per_student") @db.Decimal(12, 2)
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, slab])
  @@index([planId])
  @@map("plan_prices")
  @@schema("billing")
}

/// Percent-off discount code for subscription checkout (one use per org).
model Coupon {
  id             String    @id @default(cuid())
  code           String    @unique
  percentOff     Int       @map("percent_off") // 1–50 (floor-price guard)
  maxRedemptions Int?      @map("max_redemptions") // null = unlimited
  expiresAt      DateTime? @map("expires_at")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  redemptions CouponRedemption[]

  @@map("coupons")
  @@schema("billing")
}

model CouponRedemption {
  id            String   @id @default(cuid())
  couponId      String   @map("coupon_id")
  orgId         String   @map("org_id")
  transactionId String?  @map("transaction_id")
  createdAt     DateTime @default(now()) @map("created_at")

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@unique([couponId, orgId])
  @@index([orgId])
  @@map("coupon_redemptions")
  @@schema("billing")
}

/// Mapping of which modules a plan unlocks.
model PlanModule {
  id         String   @id @default(cuid())
  planId     String   @map("plan_id")
  moduleSlug String   @map("module_slug") // references platform.modules.slug (soft)
  createdAt  DateTime @default(now()) @map("created_at")

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, moduleSlug])
  @@index([planId])
  @@map("plan_modules")
  @@schema("billing")
}

/// Active subscription for an organization.
model Subscription {
  id                String             @id @default(cuid())
  orgId             String             @map("org_id")
  planId            String             @map("plan_id")
  status            SubscriptionStatus @default(TRIALING)
  billingCycle      BillingCycle       @default(ANNUAL) @map("billing_cycle")
  amount            Decimal            @db.Decimal(12, 2)
  discountPct       Int                @default(0) @map("discount_pct")
  trialEndsAt       DateTime?          @map("trial_ends_at")
  startedAt         DateTime?          @map("started_at")
  currentPeriodEnd  DateTime?          @map("current_period_end")
  graceEndsAt       DateTime?          @map("grace_ends_at")
  cancelAtPeriodEnd Boolean            @default(false) @map("cancel_at_period_end")
  gatewaySubId      String?            @map("gateway_sub_id") // Razorpay subscription id
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  deletedAt         DateTime?          @map("deleted_at")

  organization Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  plan         Plan               @relation(fields: [planId], references: [id])
  items        SubscriptionItem[]
  transactions Transaction[]

  @@index([orgId])
  @@index([status])
  @@map("subscriptions")
  @@schema("billing")
}

/// Line item within a subscription (module/add-on level).
model SubscriptionItem {
  id             String   @id @default(cuid())
  subscriptionId String   @map("subscription_id")
  moduleSlug     String   @map("module_slug")
  quantity       Int      @default(1)
  unitPrice      Decimal  @map("unit_price") @db.Decimal(12, 2)
  createdAt      DateTime @default(now()) @map("created_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@map("subscription_items")
  @@schema("billing")
}

/// Money movement record (GST 18%, SAC 998314; Razorpay-issued invoices).
model Transaction {
  id             String            @id @default(cuid())
  orgId          String            @map("org_id")
  subscriptionId String?           @map("subscription_id")
  type           TransactionType
  status         TransactionStatus @default(PENDING)
  amount         Decimal           @db.Decimal(12, 2)
  gstAmount      Decimal           @default(0) @map("gst_amount") @db.Decimal(12, 2)
  currency       String            @default("INR")
  gatewayRef     String?           @map("gateway_ref")
  invoiceUrl     String?           @map("invoice_url")
  metadata       Json? // credit purchases: { channel, packId, credits } — server-side grant truth
  paidAt         DateTime?         @map("paid_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([orgId])
  @@index([subscriptionId])
  @@index([status])
  @@map("transactions")
  @@schema("billing")
}

/// Per-org, per-channel message credit wallet. Free credits reset lazily
/// each UTC month (compared via periodStart); purchased credits never expire.
/// freeAllowance is edited by platform admins only.
model MessageWallet {
  id               String         @id @default(cuid())
  orgId            String         @map("org_id")
  channel          MessageChannel
  freeAllowance    Int            @default(25) @map("free_allowance")
  freeUsed         Int            @default(0) @map("free_used")
  purchasedBalance Int            @default(0) @map("purchased_balance")
  periodStart      DateTime       @default(now()) @map("period_start")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, channel])
  @@map("message_wallets")
  @@schema("billing")
}

/// Append-only credit movement trail. `ref` carries campaignId /
/// transactionId / admin userId depending on reason.
model MessageCreditLedger {
  id                    String             @id @default(cuid())
  orgId                 String             @map("org_id")
  channel               MessageChannel
  delta                 Int // negative = spend
  reason                CreditLedgerReason
  ref                   String?
  freeBalanceAfter      Int                @map("free_balance_after")
  purchasedBalanceAfter Int                @map("purchased_balance_after")
  note                  String?
  createdAt             DateTime           @default(now()) @map("created_at")

  @@index([orgId, channel, createdAt])
  @@index([ref])
  @@map("message_credit_ledger")
  @@schema("billing")
}

/// Durable outbox for the metered-send crash window: a credit debit and the
/// external provider call it pays for can't be one DB transaction (the send
/// is an HTTP call). Recorded PENDING atomically with the debit; the sender
/// confirms or refunds it right after the external call. A cron sweeps any
/// intent left PENDING past a timeout (process crashed/timed out between the
/// debit and the confirm/refund) and auto-refunds it — see
/// src/app/api/cron/credit-spend-reconcile/route.ts.
model MessageSpendIntent {
  id            String                   @id @default(cuid())
  orgId         String                   @map("org_id")
  channel       MessageChannel
  qty           Int
  fromFree      Int                      @map("from_free")
  fromPurchased Int                      @map("from_purchased")
  ref           String?
  status        MessageSpendIntentStatus @default(PENDING)
  createdAt     DateTime                 @default(now()) @map("created_at")
  confirmedAt   DateTime?                @map("confirmed_at")
  refundedAt    DateTime?                @map("refunded_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([orgId])
  @@map("message_spend_intents")
  @@schema("billing")
}

/// Bring-your-own messaging provider credentials (school's own MSG91
/// account). Auth key encrypted with the payments vault (AES-256-GCM).
/// A VERIFIED config makes sends bypass Vidhyaan credit metering.
model MessagingProviderConfig {
  id               String                  @id @default(cuid())
  orgId            String                  @map("org_id")
  channel          MessageChannel
  provider         String                  @default("MSG91")
  authKeyEncrypted String                  @map("auth_key_encrypted")
  encryptionKeyVer Int                     @default(1) @map("encryption_key_version")
  authKeyLast4     String?                 @map("auth_key_last4")
  senderId         String?                 @map("sender_id")
  smsFlowId        String?                 @map("sms_flow_id")
  whatsappNumber   String?                 @map("whatsapp_number")
  status           MessagingProviderStatus @default(DRAFT)
  verifiedAt       DateTime?               @map("verified_at")
  createdById      String?                 @map("created_by_id")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")
  deletedAt        DateTime?               @map("deleted_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, channel])
  @@map("messaging_provider_configs")
  @@schema("billing")
}

/// Referral program (Phase 2; fields scaffolded now per spec).
model Referral {
  id            String         @id @default(cuid())
  referrerOrgId String         @map("referrer_org_id") // soft reference to organizations
  refereeOrgId  String?        @map("referee_org_id") // soft reference
  code          String         @unique
  status        ReferralStatus @default(PENDING)
  rewardAmount  Decimal?       @map("reward_amount") @db.Decimal(12, 2)
  rewardedAt    DateTime?      @map("rewarded_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@index([referrerOrgId])
  @@index([status])
  @@map("referrals")
  @@schema("billing")
}

model PlatformSettings {
  id                    String         @id @default("default")
  freePlanLeadCap       Int            @default(10) @map("free_plan_lead_cap")
  trialDurationDays     Int            @default(7) @map("trial_duration_days")
  defaultOtpTtlMinutes  Int            @default(10) @map("default_otp_ttl_minutes")
  enableWhatsapp        Boolean        @default(false) @map("enable_whatsapp")
  // These three default ON: they are platform-wide kill-switches, so the safe
  // default is "feature available" (matches pre-flag behaviour). Turning one
  // off disables that capability across every org.
  enableCampaignModule  Boolean        @default(true) @map("enable_campaign_module")
  enableAiFeatures      Boolean        @default(true) @map("enable_ai_features")
  enablePublicApiAccess Boolean        @default(true) @map("enable_public_api_access")
  maintenanceMode       Boolean        @default(false) @map("maintenance_mode")
  // Billing cycles orgs may subscribe with (any combination, min 1)
  enabledBillingCycles  BillingCycle[] @default([MONTHLY, ANNUAL]) @map("enabled_billing_cycles")
  // true → catalog prices are the final amount (GST carved out on the invoice);
  // false → 18% GST is added on top at checkout
  pricesIncludeGst      Boolean        @default(false) @map("prices_include_gst")
  // Platform GST-invoice number sequence (receipt "VID<year>-<seq>") —
  // atomic increment on this singleton row, never count()+1
  invoiceSeq            Int            @default(0) @map("invoice_seq")
  // Seller details printed on subscription GST invoices
  signatoryName         String?        @map("signatory_name")
  signatoryImageUrl     String?        @map("signatory_image_url")
  stampImageUrl         String?        @map("stamp_image_url")
  businessName          String?        @map("business_name")
  businessAddress       String?        @map("business_address")
  businessGstin         String?        @map("business_gstin")
  fromEmailAddress      String?        @map("from_email_address")
  supportEmail          String?        @map("support_email")
  fromName              String?        @map("from_name")
  opsAlertEmail         String?        @map("ops_alert_email")
  slackWebhookUrl       String?        @map("slack_webhook_url")
  razorpayLiveKey       String?        @map("razorpay_live_key")
  razorpayWebhookSecret String?        @map("razorpay_webhook_secret")
  doSpacesEndpoint      String?        @map("do_spaces_endpoint")
  doSpacesBucket        String?        @map("do_spaces_bucket")
  doSpacesCdnUrl        String?        @map("do_spaces_cdn_url")

  // --- Admin-managed integration credentials (Phase 3) ---
  // Secrets stored as vault ciphertext (see src/lib/payments/vault.ts).
  // All optional: when null the platform-config resolver falls back to the
  // corresponding process.env value, so an empty row = today's env behaviour.
  razorpayKeyId            String? @map("razorpay_key_id") // key_id (semi-public)
  razorpayKeySecretEnc     String? @map("razorpay_key_secret_enc") // key_secret (encrypted)
  razorpayWebhookSecretEnc String? @map("razorpay_webhook_secret_enc") // webhook secret (encrypted)
  s3Region                 String? @map("s3_region")
  s3AccessKeyId            String? @map("s3_access_key_id")
  s3SecretKeyEnc           String? @map("s3_secret_key_enc") // encrypted
  zeptoTokenEnc            String? @map("zepto_token_enc") // encrypted
  zeptoFromEmail           String? @map("zepto_from_email")
  zeptoCampaignEmail       String? @map("zepto_campaign_email")
  msg91AuthKeyEnc          String? @map("msg91_auth_key_enc") // encrypted
  msg91WhatsappNumber      String? @map("msg91_whatsapp_number")
  msg91SenderId            String? @map("msg91_sender_id")
  // Meta WhatsApp Cloud API (direct, no BSP). When configured, platform
  // shared-account WhatsApp sends go through graph.facebook.com instead of
  // MSG91. System-user permanent token, encrypted at rest.
  metaWaAccessTokenEnc     String? @map("meta_wa_access_token_enc") // encrypted
  metaWaPhoneNumberId      String? @map("meta_wa_phone_number_id")
  metaWaBusinessAccountId  String? @map("meta_wa_business_account_id") // WABA id (template sync)
  metaWaAppSecretEnc       String? @map("meta_wa_app_secret_enc") // encrypted — webhook signature check
  metaWaWebhookVerifyToken String? @map("meta_wa_webhook_verify_token")

  // Usage & ROI model (admin-configurable) for the org usage dashboard.
  // usageHourlyRate: blended staff cost (₹/hour). usageMinutesPerAction:
  // JSON map of module-slug → minutes saved per tracked action.
  usageHourlyRate       Int?  @default(300) @map("usage_hourly_rate")
  usageMinutesPerAction Json? @map("usage_minutes_per_action")

  // Optional external uptime monitor (UptimeRobot read-only API key, encrypted).
  // When set, the admin dashboard shows a real uptime %.
  uptimeRobotApiKeyEnc String? @map("uptime_robot_api_key_enc")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
  @@schema("platform")
}

/// Global opt-out list for the platform shared WhatsApp number. A parent
/// replying STOP opts out of every org's messages from this number (the
/// sender identity is shared, so consent is too). Phone = 10-digit normalized.
model WhatsappOptOut {
  id        String   @id @default(cuid())
  phone     String   @unique
  reason    String   @default("STOP")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("whatsapp_opt_outs")
  @@schema("platform")
}

/// Inbound WhatsApp messages received on the platform shared number.
/// orgId = best-effort attribution (last org that messaged this phone).
model WhatsappInboundMessage {
  id        String   @id @default(cuid())
  wamid     String?  @unique
  phone     String
  body      String
  orgId     String?  @map("org_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([phone])
  @@index([orgId, createdAt])
  @@map("whatsapp_inbound_messages")
  @@schema("platform")
}

// Append-only feature-usage event log. Written fire-and-forget from the API
// composer (one row per meaningful org action) to power the per-org usage
// dashboard in the admin portal. No FK to Organization on purpose — keeps the
// write cheap and the table independent of tenant cascades.
model FeatureUsageEvent {
  id        String   @id @default(cuid())
  orgId     String   @map("org_id")
  userId    String?  @map("user_id")
  feature   String
  action    String
  path      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([orgId, feature, createdAt])
  @@index([orgId, createdAt])
  @@map("feature_usage_events")
  @@schema("platform")
}

// Pre-aggregated daily usage per org+feature. Populated by the usage-rollup
// cron so raw events/heartbeats can be pruned on a retention window while
// long-range history is preserved. One row per (org, day, feature).
model UsageDailyRollup {
  id            String   @id @default(cuid())
  orgId         String   @map("org_id")
  day           DateTime @db.Date
  feature       String
  actions       Int      @default(0)
  activeUsers   Int      @default(0) @map("active_users")
  activeMinutes Int      @default(0) @map("active_minutes")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([orgId, day, feature])
  @@index([orgId, day])
  @@map("usage_daily_rollups")
  @@schema("platform")
}

// Active-time signal for the org usage dashboard. One row per ~60s heartbeat
// emitted by the CRM client while a tab is visible/focused. Active minutes are
// derived by counting distinct per-minute buckets (dedupes bursts/retries).
model UsageHeartbeat {
  id        String   @id @default(cuid())
  orgId     String   @map("org_id")
  userId    String   @map("user_id")
  feature   String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([orgId, createdAt])
  @@index([orgId, userId, feature, createdAt])
  @@map("usage_heartbeats")
  @@schema("platform")
}

model Term {
  id             String   @id @default(cuid())
  orgId          String   @map("org_id")
  academicYearId String   @map("academic_year_id")
  name           String
  startDate      DateTime @map("start_date")
  endDate        DateTime @map("end_date")
  order          Int      @default(0)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  invoices     Invoice[]

  @@index([orgId])
  @@index([academicYearId])
  @@map("terms")
  @@schema("crm")
}

model Course {
  id             String          @id @default(cuid())
  orgId          String          @map("org_id")
  name           String
  description    String?
  category       CenterCategory?
  amount         Decimal         @db.Decimal(10, 2)
  frequency      FeeFrequency    @default(MONTHLY)
  billingDay     Int             @default(1) @map("billing_day")
  durationMonths Int?            @map("duration_months")
  // Custom-schedule inputs (LC): weekly cadence hint + total package hours.
  // Session generation for a per-student custom schedule stops once totalHours
  // is consumed (see src/lib/schedule/materialize.ts). Both optional/backward-safe.
  hoursPerWeek   Int?            @map("hours_per_week")
  totalHours     Int?            @map("total_hours")
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  deletedAt      DateTime?       @map("deleted_at")

  organization       Organization             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  enrollments        CourseEnrollment[]
  invoices           Invoice[]
  attendanceSessions AttendanceSession[]
  batches            StudentBatch[]
  teacherAssignments TeacherAssignment[]
  feePlanTemplates   FeePlanTemplate[]
  courseSessions     CourseSession[]
  scheduleSlots      EnrollmentScheduleSlot[]

  @@index([orgId])
  @@map("courses")
  @@schema("crm")
}

model CourseEnrollment {
  id              String           @id @default(cuid())
  orgId           String           @map("org_id")
  studentId       String           @map("student_id")
  courseId        String           @map("course_id")
  startDate       DateTime         @map("start_date")
  endDate         DateTime?        @map("end_date")
  status          EnrollmentStatus @default(ACTIVE)
  nextBillingDate DateTime?        @map("next_billing_date")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  organization  Organization             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  student       Student                  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course        Course                   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  scheduleSlots EnrollmentScheduleSlot[]

  @@unique([studentId, courseId])
  @@index([orgId])
  @@index([studentId])
  @@index([courseId])
  @@map("course_enrollments")
  @@schema("crm")
}

/// Per-student individual weekly schedule for a course enrolment (LC 1-on-1 /
/// custom schedules). A student is EITHER assigned to a batch (shared cohort
/// sessions) OR carries these slots (per-student sessions) — never both. The
/// materializer (src/lib/schedule/materialize.ts) rolls each active slot into
/// per-student CourseSession + AttendanceSession rows, bounded by
/// startDate/endDate and the course totalHours cap.
model EnrollmentScheduleSlot {
  id           String    @id @default(cuid())
  orgId        String    @map("org_id")
  enrollmentId String    @map("enrollment_id")
  studentId    String    @map("student_id")
  courseId     String    @map("course_id")
  dayOfWeek    Int       @map("day_of_week") // ISO 1=Mon..7=Sun
  startTime    String    @map("start_time") // HH:mm
  endTime      String    @map("end_time") // HH:mm
  durationMin  Int?      @map("duration_min") // else endTime-startTime diff
  teacherId    String?   @map("teacher_id") // soft ref (User)
  room         String?
  startDate    DateTime? @map("start_date")
  endDate      DateTime? @map("end_date")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  organization Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  enrollment   CourseEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  student      Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course       Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, dayOfWeek, startTime])
  @@index([orgId])
  @@index([studentId])
  @@index([enrollmentId])
  @@map("enrollment_schedule_slots")
  @@schema("crm")
}

enum AssignmentStatus {
  ACTIVE
  SUSPENDED
  REVOKED

  @@schema("platform")
}

model UserRoleAssignment {
  id         String           @id @default(cuid())
  userId     String           @map("user_id")
  role       UserRole
  orgId      String?          @map("org_id")
  status     AssignmentStatus @default(ACTIVE)
  isDefault  Boolean          @default(false)
  lastUsedAt DateTime?        @map("last_used_at")
  createdAt  DateTime         @default(now()) @map("created_at")

  user User          @relation(fields: [userId], references: [id])
  org  Organization? @relation(fields: [orgId], references: [id])

  @@unique([userId, role, orgId])
  @@index([userId])
  @@index([orgId])
  @@map("user_role_assignments")
  @@schema("platform")
}

// ============================================================
// PAYMENT GATEWAY (per-org fee collection — see
// docs/design/payment-gateway-integration.md)
// ============================================================

enum GatewayProvider {
  RAZORPAY
  STRIPE
  CASHFREE
  PAYU

  @@schema("billing")
}

enum GatewayEnvironment {
  TEST
  LIVE

  @@schema("billing")
}

enum GatewayConfigStatus {
  DRAFT
  VERIFIED
  ACTIVE
  DISABLED
  SUSPENDED

  @@schema("billing")
}

enum GatewayOrderStatus {
  CREATED
  ATTEMPTED
  PAID
  FAILED
  EXPIRED

  @@schema("billing")
}

enum RefundStatus {
  PENDING
  PROCESSED
  FAILED

  @@schema("billing")
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  SKIPPED
  FAILED

  @@schema("billing")
}

enum LedgerEntryType {
  CHARGE
  PAYMENT
  REFUND
  CONCESSION
  ADJUSTMENT

  @@schema("crm")
}

/// Per-org, per-provider, per-environment gateway credentials + policy.
/// Secrets encrypted with AES-256-GCM (src/lib/payments/vault.ts).
model PaymentGatewayConfig {
  id                 String              @id @default(cuid())
  orgId              String              @map("org_id")
  provider           GatewayProvider     @default(RAZORPAY)
  environment        GatewayEnvironment  @default(TEST)
  status             GatewayConfigStatus @default(DRAFT)
  isCurrent          Boolean             @default(false) @map("is_current")
  keyIdEncrypted     String              @map("key_id_encrypted")
  keySecretEncrypted String              @map("key_secret_encrypted")
  webhookSecretEnc   String              @map("webhook_secret_encrypted")
  encryptionKeyVer   Int                 @default(1) @map("encryption_key_version")
  keyIdLast4         String?             @map("key_id_last4")
  allowPartial       Boolean             @default(true) @map("allow_partial")
  minPartialAmount   Decimal?            @map("min_partial_amount") @db.Decimal(12, 2)
  verifiedAt         DateTime?           @map("verified_at")
  webhookVerifiedAt  DateTime?           @map("webhook_verified_at")
  lastWebhookAt      DateTime?           @map("last_webhook_at")
  createdById        String?             @map("created_by_id") // soft reference
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  deletedAt          DateTime?           @map("deleted_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, provider, environment])
  @@index([orgId, status])
  @@map("payment_gateway_configs")
  @@schema("billing")
}

/// One provider order per checkout intent; amount fixed at creation.
model GatewayOrder {
  id                String             @id @default(cuid())
  orgId             String             @map("org_id")
  provider          GatewayProvider
  environment       GatewayEnvironment
  invoiceId         String             @map("invoice_id")
  studentId         String?            @map("student_id") // soft reference
  parentId          String?            @map("parent_id") // soft reference; who initiated
  amount            Decimal            @db.Decimal(12, 2) // rupees; paise only at provider edge
  currency          String             @default("INR")
  status            GatewayOrderStatus @default(CREATED)
  providerOrderId   String             @map("provider_order_id")
  providerPaymentId String?            @map("provider_payment_id")
  failureCode       String?            @map("failure_code")
  failureReason     String?            @map("failure_reason")
  paymentId         String?            @unique @map("payment_id") // soft reference → crm.payments
  expiresAt         DateTime           @map("expires_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invoice      Invoice      @relation(fields: [invoiceId], references: [id])

  @@unique([provider, providerOrderId])
  @@index([orgId, status])
  @@index([orgId, invoiceId])
  @@index([status, expiresAt])
  @@map("gateway_orders")
  @@schema("billing")
}

/// Every inbound gateway webhook, verified or not — idempotency, audit, replay.
model WebhookEvent {
  id              String             @id @default(cuid())
  orgId           String?            @map("org_id") // soft reference; null if unresolvable
  provider        GatewayProvider
  providerEventId String             @map("provider_event_id")
  eventType       String             @map("event_type")
  status          WebhookEventStatus @default(RECEIVED)
  signatureValid  Boolean            @map("signature_valid")
  payload         Json
  error           String?
  processedAt     DateTime?          @map("processed_at")
  attempts        Int                @default(0)
  createdAt       DateTime           @default(now()) @map("created_at")

  @@unique([provider, providerEventId])
  @@index([orgId, createdAt])
  @@index([status, createdAt])
  @@map("webhook_events")
  @@schema("billing")
}

/// Gateway refund against a fee payment.
model Refund {
  id               String       @id @default(cuid())
  orgId            String       @map("org_id")
  paymentId        String       @map("payment_id")
  gatewayOrderId   String?      @map("gateway_order_id") // soft reference
  amount           Decimal      @db.Decimal(12, 2)
  status           RefundStatus @default(PENDING)
  providerRefundId String?      @map("provider_refund_id")
  reason           String?
  initiatedById    String       @map("initiated_by_id") // soft reference
  processedAt      DateTime?    @map("processed_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  payment      Payment      @relation(fields: [paymentId], references: [id])

  @@unique([orgId, providerRefundId])
  @@index([orgId, status])
  @@index([paymentId])
  @@map("refunds")
  @@schema("billing")
}

/// Append-only student money ledger. Debits = charges, credits = payments;
/// refund reversals are debits. Corrections are compensating ADJUSTMENT
/// entries — rows are never edited.
model LedgerEntry {
  id          String          @id @default(cuid())
  orgId       String          @map("org_id")
  studentId   String          @map("student_id")
  invoiceId   String?         @map("invoice_id") // soft reference
  paymentId   String?         @map("payment_id") // soft reference
  refundId    String?         @map("refund_id") // soft reference
  type        LedgerEntryType
  debit       Decimal         @default(0) @db.Decimal(12, 2)
  credit      Decimal         @default(0) @db.Decimal(12, 2)
  balance     Decimal         @db.Decimal(12, 2) // running balance snapshot
  description String
  createdAt   DateTime        @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [studentId], references: [id])

  @@index([orgId, studentId, createdAt])
  @@index([invoiceId])
  @@map("ledger_entries")
  @@schema("crm")
}

enum GuardianLinkStatus {
  INVITED
  ACTIVE
  REVOKED

  @@schema("crm")
}

/// Explicit, auditable link between a CRM student and a marketplace parent
/// account. Created when a school enables parent-portal access; supersedes
/// the implicit guardian-phone match (kept as bootstrap fallback).
model StudentGuardianLink {
  id          String             @id @default(cuid())
  orgId       String             @map("org_id")
  studentId   String             @map("student_id")
  parentId    String             @map("parent_id")
  relation    String? // FATHER / MOTHER / GUARDIAN — free text for now
  status      GuardianLinkStatus @default(INVITED)
  invitedById String?            @map("invited_by_id") // soft reference
  invitedAt   DateTime           @default(now()) @map("invited_at")
  activatedAt DateTime?          @map("activated_at") // first OTP login after invite
  revokedAt   DateTime?          @map("revoked_at")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent       Parent       @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([studentId, parentId])
  @@index([orgId, studentId])
  @@index([parentId, status])
  @@map("student_guardian_links")
  @@schema("crm")
}

// ============================================================================
// REPORTING SCHEMA — aggregates + user preferences only, no operational data.
// See docs/reports-analytics-phase1-prd.md.
// ============================================================================

/// Nightly per-day aggregates written by /api/cron/reports-rollup.
/// Idempotency is delete-then-insert per org×date window (nullable grain
/// columns rule out a usable unique constraint). No FKs into operational
/// tables — rollups must survive soft deletes.
model DailyRollup {
  id             String   @id @default(cuid())
  orgId          String   @map("org_id")
  branchId       String?  @map("branch_id")
  academicYearId String?  @map("academic_year_id")
  date           DateTime @db.Date
  metric         String // leads_created | leads_contacted | admissions_started
  // | admissions_admitted | invoiced_amount | collected_amount
  // | concession_amount | students_active | campaign_credits_spent
  dimension      String? // source | method | type | channel
  dimensionValue String?  @map("dimension_value")
  count          Int      @default(0)
  amount         Decimal? @db.Decimal(12, 2)

  @@index([orgId, metric, date])
  @@index([orgId, academicYearId, metric])
  @@index([orgId, date])
  @@map("daily_rollups")
  @@schema("reporting")
}

/// Named filter set a user saved on a report.
model ReportSavedView {
  id        String   @id @default(cuid())
  orgId     String   @map("org_id")
  userId    String   @map("user_id")
  reportKey String   @map("report_key")
  name      String
  filters   Json
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, reportKey, name])
  @@index([orgId, userId])
  @@map("report_saved_views")
  @@schema("reporting")
}

/// Favourite flag + recency, one row per user per report.
model ReportUsage {
  id           String    @id @default(cuid())
  orgId        String    @map("org_id")
  userId       String    @map("user_id")
  reportKey    String    @map("report_key")
  isFavourite  Boolean   @default(false) @map("is_favourite")
  lastViewedAt DateTime? @map("last_viewed_at")
  viewCount    Int       @default(0) @map("view_count")

  @@unique([userId, reportKey])
  @@index([orgId, userId, lastViewedAt])
  @@map("report_usage")
  @@schema("reporting")
}

/// Phase 2 — scheduled report delivery. Table shipped now, feature later.
model ReportSchedule {
  id          String    @id @default(cuid())
  orgId       String    @map("org_id")
  userId      String    @map("user_id")
  reportKey   String    @map("report_key")
  savedViewId String?   @map("saved_view_id")
  cadence     String // validated token e.g. 'weekly_mon_08', not raw cron
  channel     String    @default("email")
  recipients  Json
  enabled     Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  // Delivery feedback: last attempt outcome, surfaced in the Schedule popover.
  lastRunAt   DateTime? @map("last_run_at")
  lastStatus  String?   @map("last_status") // 'sent' | 'skipped' | 'error'
  lastError   String?   @map("last_error")

  @@index([orgId, enabled])
  @@map("report_schedules")
  @@schema("reporting")
}

// ============================================================
// ATTENDANCE (module slug: 'attendance')
// School/junior-college = daily marks (sessionKey 'DAY');
// learning/coaching centres = per-session marks keyed to a course/batch
// AttendanceSession. See docs/plans + src/lib/attendance/.
// ============================================================

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
  HOLIDAY

  @@schema("crm")
}

enum AttendanceSource {
  MANUAL
  BIOMETRIC
  AUTO_ONLINE
  API

  @@schema("crm")
}

model AttendanceRecord {
  id             String           @id @default(cuid())
  orgId          String           @map("org_id")
  branchId       String?          @map("branch_id")
  academicYearId String?          @map("academic_year_id")
  studentId      String           @map("student_id")
  date           DateTime         @db.Date
  sessionId      String?          @map("session_id")
  // sessionId ?? 'DAY' — non-null stand-in so the unique constraint can
  // dedupe daily marks (Postgres treats NULLs as distinct in uniques).
  sessionKey     String           @default("DAY") @map("session_key")
  status         AttendanceStatus
  source         AttendanceSource @default(MANUAL)
  checkInAt      DateTime?        @map("check_in_at")
  checkOutAt     DateTime?        @map("check_out_at")
  note           String?
  markedById     String?          @map("marked_by_id")
  updatedById    String?          @map("updated_by_id")
  alertSentAt    DateTime?        @map("alert_sent_at") // absence-alert once-only stamp
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  organization Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  student      Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session      AttendanceSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  academicYear AcademicYear?      @relation(fields: [academicYearId], references: [id])
  markedBy     User?              @relation("AttendanceMarkedBy", fields: [markedById], references: [id])

  @@unique([orgId, studentId, date, sessionKey])
  @@index([orgId, date])
  @@index([orgId, academicYearId, date])
  @@index([orgId, studentId, date])
  @@index([sessionId])
  @@index([branchId])
  @@map("attendance_records")
  @@schema("crm")
}

/// One scheduled class occurrence for LC/coaching orgs (course XOR batch).
model AttendanceSession {
  id             String    @id @default(cuid())
  orgId          String    @map("org_id")
  branchId       String?   @map("branch_id")
  academicYearId String?   @map("academic_year_id")
  date           DateTime  @db.Date
  courseId       String?   @map("course_id")
  batchId        String?   @map("batch_id")
  // Per-student custom-schedule sessions carry these (soft references); cohort
  // batch sessions leave them null. Lets a per-student session be marked for a
  // single student rather than a whole cohort.
  studentId      String?   @map("student_id")
  enrollmentId   String?   @map("enrollment_id")
  scheduleSlotId String?   @map("schedule_slot_id")
  // School period sessions (materialized from the class timetable) carry the
  // class scope + subject so the register loads the right roster; timetableSlotId
  // is a soft ref back to the recurring TimetableSlot.
  timetableSlotId String?  @map("timetable_slot_id")
  gradeLabel     String?   @map("grade_label")
  section        String?
  subject        String?
  title          String?
  startsAt       DateTime? @map("starts_at")
  endsAt         DateTime? @map("ends_at")
  deliveryMode   String    @default("IN_PERSON") @map("delivery_mode") // IN_PERSON | ONLINE
  createdById    String?   @map("created_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  course       Course?            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  batch        StudentBatch?      @relation(fields: [batchId], references: [id], onDelete: Cascade)
  records      AttendanceRecord[]

  @@index([orgId, date])
  @@index([courseId])
  @@index([batchId])
  @@index([studentId])
  @@index([timetableSlotId])
  @@map("attendance_sessions")
  @@schema("crm")
}

/// Teacher -> marking target. School mode: gradeLabel(+section); LC mode:
/// courseId or batchId. targetKey is the joined tuple so the unique works
/// despite nullable columns.
model TeacherAssignment {
  id             String   @id @default(cuid())
  orgId          String   @map("org_id")
  teacherId      String   @map("teacher_id")
  academicYearId String?  @map("academic_year_id")
  gradeLabel     String?  @map("grade_label")
  section        String?
  courseId       String?  @map("course_id")
  batchId        String?  @map("batch_id")
  targetKey      String   @map("target_key") // `${gradeLabel}|${section}|${courseId}|${batchId}`
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  teacher      User          @relation("TeacherAssignments", fields: [teacherId], references: [id], onDelete: Cascade)
  course       Course?       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  batch        StudentBatch? @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([orgId, teacherId, targetKey])
  @@index([orgId, teacherId])
  @@map("teacher_assignments")
  @@schema("crm")
}

enum CourseSessionStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  CANCELLED

  @@schema("crm")
}

/// One occurrence of a batch's recurring class. Materialized ~2 weeks ahead
/// from StudentBatch.daysOfWeek/startTime/sessionDurationMin (see
/// src/lib/schedule/materialize.ts), idempotent on (batchId, startsAt).
/// One-off reschedule/cancel edits mutate this row only — they never touch
/// the batch pattern, so the next materializer run keeps generating the
/// untouched future occurrences.
model CourseSession {
  id                  String              @id @default(cuid())
  orgId               String              @map("org_id")
  branchId            String?             @map("branch_id")
  academicYearId      String?             @map("academic_year_id")
  courseId            String?             @map("course_id")
  // batchId nullable now: a session comes from EITHER a cohort batch (shared) OR
  // a per-student custom schedule (scheduleSlotId + studentId). Exactly one of
  // batchId / scheduleSlotId is set. studentId/enrollmentId are soft references.
  batchId             String?             @map("batch_id")
  studentId           String?             @map("student_id") // soft ref (Student) — per-student sessions only
  enrollmentId        String?             @map("enrollment_id") // soft ref (CourseEnrollment) — per-student sessions only
  scheduleSlotId      String?             @map("schedule_slot_id") // soft ref (EnrollmentScheduleSlot) — per-student sessions only
  // School period sessions (materialized from the class timetable): scoped by
  // class/section + subject, linked back to the recurring TimetableSlot.
  timetableSlotId     String?             @map("timetable_slot_id")
  gradeLabel          String?             @map("grade_label")
  section             String?
  subject             String?
  teacherId           String?             @map("teacher_id") // soft reference (User) — set from TeacherAssignment at materialize time, editable via reschedule
  startsAt            DateTime            @map("starts_at")
  durationMin         Int                 @map("duration_min")
  status              CourseSessionStatus @default(SCHEDULED)
  meetingLink         String?             @map("meeting_link")
  rescheduledFromId   String?             @map("rescheduled_from_id") // soft reference (CourseSession) — set on the new row when a reschedule creates one
  cancelReason        String?             @map("cancel_reason")
  attendanceSessionId String?             @map("attendance_session_id") // soft reference (AttendanceSession) — 1:1, created alongside the session
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  deletedAt           DateTime?           @map("deleted_at")

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  course       Course?       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  batch        StudentBatch? @relation(fields: [batchId], references: [id], onDelete: Cascade)

  // Idempotency per source (Postgres treats NULLs as distinct, so each partial
  // key only constrains its own source): batch cohort, per-student custom
  // schedule, and school timetable period.
  @@unique([batchId, startsAt])
  @@unique([scheduleSlotId, startsAt])
  @@unique([timetableSlotId, startsAt])
  @@index([orgId, startsAt])
  @@index([teacherId, startsAt])
  @@index([studentId, startsAt])
  @@index([courseId])
  @@map("course_sessions")
  @@schema("crm")
}

model Holiday {
  id             String   @id @default(cuid())
  orgId          String   @map("org_id")
  academicYearId String?  @map("academic_year_id")
  date           DateTime @db.Date
  name           String
  /// CUSTOM (org-added) | NATIONAL (seeded from the platform national-holiday list)
  source         String   @default("CUSTOM")
  /// Optional greeting line shown on the dashboard banner ("School reopens Monday")
  message        String?
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, date])
  @@index([orgId, academicYearId])
  @@map("holidays")
  @@schema("crm")
}

/// Registered biometric device. Ingest auth = sha256(x-device-key) lookup.
model BiometricDevice {
  id           String    @id @default(cuid())
  orgId        String    @map("org_id")
  branchId     String?   @map("branch_id")
  name         String
  vendor       String? // ESSL | REALTIME | OTHER (free text)
  serialNumber String?   @map("serial_number")
  apiKeyPrefix String    @map("api_key_prefix") // display hint only
  apiKeyHash   String    @unique @map("api_key_hash") // sha256(token)
  isActive     Boolean   @default(true) @map("is_active")
  lastSeenAt   DateTime? @map("last_seen_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  organization Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  identities   BiometricIdentity[]
  events       BiometricEvent[]

  @@index([orgId])
  @@map("biometric_devices")
  @@schema("crm")
}

/// Maps the user id enrolled on a device to a CRM student.
model BiometricIdentity {
  id           String   @id @default(cuid())
  orgId        String   @map("org_id")
  deviceId     String?  @map("device_id") // null = org-wide mapping
  deviceUserId String   @map("device_user_id")
  studentId    String   @map("student_id")
  createdAt    DateTime @default(now()) @map("created_at")

  organization Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  device       BiometricDevice? @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  student      Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([orgId, deviceUserId])
  @@index([studentId])
  @@map("biometric_identities")
  @@schema("crm")
}

/// Raw punch events pushed by devices. Written by the public ingest route
/// via the base client (device key is the security boundary) — deliberately
/// NOT in TENANT_MODELS. Unique constraint makes re-pushes idempotent.
model BiometricEvent {
  id           String   @id @default(cuid())
  orgId        String   @map("org_id")
  deviceId     String   @map("device_id")
  deviceUserId String   @map("device_user_id")
  eventAt      DateTime @map("event_at")
  direction    String? // in | out
  payload      Json?
  status       String   @default("PENDING") // PROCESSED | UNMATCHED
  studentId    String?  @map("student_id")
  createdAt    DateTime @default(now()) @map("created_at")

  device BiometricDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@unique([deviceId, deviceUserId, eventAt])
  @@index([orgId, status])
  @@map("biometric_events")
  @@schema("crm")
}

// ============================================================
// CLASS / SECTION MASTER (schools & junior colleges)
// Source of truth for class+section dropdowns across lead →
// admission → student → fees → attendance. Records still STORE
// the name string (Student.gradeLabel/section) — master drives
// options only; gradeSlug bridges Lead.gradeSought slug values.
// LC/coaching orgs use Course + StudentBatch instead.
// ============================================================

model SchoolClass {
  id        String    @id @default(cuid())
  orgId     String    @map("org_id")
  branchId  String?   @map("branch_id")
  name      String // canonical label, matches Student.gradeLabel ("Class 5")
  gradeSlug String?   @map("grade_slug") // mapGradeValue(name)
  sortOrder Int       @default(0) @map("sort_order") // ladder position
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  organization Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch       Branch?        @relation(fields: [branchId], references: [id])
  sections     ClassSection[]

  @@unique([orgId, name])
  @@index([orgId, sortOrder])
  @@map("school_classes")
  @@schema("crm")
}

model ClassSection {
  id        String   @id @default(cuid())
  orgId     String   @map("org_id")
  classId   String   @map("class_id")
  name      String // "A", "B" — matches Student.section
  capacity  Int?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  schoolClass  SchoolClass  @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([classId, name])
  @@index([orgId])
  @@map("class_sections")
  @@schema("crm")
}

/// Parent-raised leave application for a linked student. Staff review flips
/// status; APPROVED days are informational (attendance register stays the
/// source of truth, marked by staff as LEAVE).
model LeaveRequest {
  id           String    @id @default(cuid())
  orgId        String    @map("org_id")
  studentId    String    @map("student_id")
  parentId     String    @map("parent_id") // soft ref → marketplace.parents
  fromDate     DateTime  @map("from_date") @db.Date
  toDate       DateTime  @map("to_date") @db.Date
  reason       String
  status       String    @default("PENDING") // PENDING | APPROVED | REJECTED | CANCELLED
  reviewNote   String?   @map("review_note")
  reviewedById String?   @map("reviewed_by_id") // soft ref → platform.users
  reviewedAt   DateTime? @map("reviewed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([orgId, studentId])
  @@index([orgId, status])
  @@map("leave_requests")
  @@schema("crm")
}

/// A single subject mark in an exam. Grouped by examName for the parent
/// report card; staff entry UI arrives later (bulk import/API for now).
model ExamResult {
  id             String    @id @default(cuid())
  orgId          String    @map("org_id")
  studentId      String    @map("student_id")
  academicYearId String?   @map("academic_year_id")
  termId         String?   @map("term_id") // soft ref — display only
  examName       String    @map("exam_name") // "Mid-Term Exam", "Unit Test 1"
  subject        String
  maxMarks       Decimal   @default(100) @map("max_marks") @db.Decimal(6, 2)
  marksObtained  Decimal   @map("marks_obtained") @db.Decimal(6, 2)
  grade          String? // "A+", "B"...
  remarks        String?
  examDate       DateTime? @map("exam_date") @db.Date
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, examName, subject])
  @@index([orgId, studentId])
  @@map("exam_results")
  @@schema("crm")
}

/// Weekly class timetable (schools). Grade/section stored as strings to
/// match Student.gradeLabel/section — the class master only drives dropdowns.
model TimetableSlot {
  id             String   @id @default(cuid())
  orgId          String   @map("org_id")
  branchId       String?  @map("branch_id")
  academicYearId String?  @map("academic_year_id")
  gradeLabel     String   @map("grade_label")
  section        String?
  // section ?? 'ALL' — non-null stand-in so the unique constraint can dedupe
  // whole-class slots (Postgres treats NULLs as distinct in uniques).
  sectionKey     String   @default("ALL") @map("section_key")
  dayOfWeek      Int      @map("day_of_week") // ISO: 1=Mon .. 7=Sun
  startTime      String   @map("start_time") // HH:mm (matches StudentBatch)
  endTime        String   @map("end_time") // HH:mm
  subject        String
  teacherId      String?  @map("teacher_id")
  room           String?
  // Recurring cancel: the period stops running from now on but stays visible
  // (struck-through) as a record. One-off per-date cancels live in
  // TimetableException instead. cancelledById is a soft ref (platform.users).
  cancelledAt    DateTime? @map("cancelled_at")
  cancelReason   String?   @map("cancel_reason")
  cancelledById  String?   @map("cancelled_by_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  teacher      User?                @relation("TimetableTeacher", fields: [teacherId], references: [id])
  exceptions   TimetableException[]

  @@unique([orgId, gradeLabel, sectionKey, dayOfWeek, startTime])
  @@index([orgId, gradeLabel, sectionKey])
  @@index([orgId, teacherId])
  @@map("timetable_slots")
  @@schema("crm")
}

/// One-off cancellation of a recurring timetable period on a specific date
/// ("this Monday's 9am Maths is off"). The recurring slot stays; views hide/
/// strike the period only on the matching date. createdById is a soft ref.
model TimetableException {
  id          String   @id @default(cuid())
  orgId       String   @map("org_id")
  slotId      String   @map("slot_id")
  date        DateTime @db.Date
  reason      String?
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  slot         TimetableSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@unique([slotId, date])
  @@index([orgId, date])
  @@map("timetable_exceptions")
  @@schema("crm")
}

// ============================================================
// EMAIL SUPPRESSION (platform-wide)
// Hard-bounced addresses from the ZeptoMail webhook. Senders in
// src/lib/integrations/zeptomail skip these to protect domain
// reputation. Address is bad regardless of org → platform schema.
// ============================================================

model EmailSuppression {
  id        String   @id @default(cuid())
  email     String   @unique // stored lowercased
  reason    String // hardbounce | complaint | manual
  source    String? // zeptomail-webhook | admin
  detail    String? // provider bounce reason text
  createdAt DateTime @default(now()) @map("created_at")

  @@map("email_suppressions")
  @@schema("platform")
}

/// One row per (user, device) mobile app session. Holds the rotating
/// refresh-token hash (raw token never stored) and the Expo push token.
model MobileDevice {
  id                   String    @id @default(cuid())
  userId               String    @map("user_id")
  deviceId             String    @map("device_id") // stable client-generated id
  platform             String // ios | android
  deviceName           String?   @map("device_name")
  pushToken            String?   @map("push_token") // Expo push token
  assignmentId         String?   @map("assignment_id") // last selected workspace
  refreshTokenHash     String?   @map("refresh_token_hash")
  prevRefreshTokenHash String?   @map("prev_refresh_token_hash") // reuse detection only
  refreshExpiresAt     DateTime? @map("refresh_expires_at")
  lastSeenAt           DateTime  @default(now()) @map("last_seen_at")
  revokedAt            DateTime? @map("revoked_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([deviceId])
  @@map("mobile_devices")
  @@schema("platform")
}
