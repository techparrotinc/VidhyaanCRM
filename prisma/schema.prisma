// ============================================================================
// SCHEMA: platform — Vidhyaan core management
// ============================================================================

/// Tenant root. One row per customer organization (school / learning center).
model Organization {
  id                String          @id @default(cuid())
  name              String
  slug              String          @unique
  institutionType   InstitutionType @map("institution_type")
  email             String
  phone             String
  gstNumber         String?         @map("gst_number")
  status            OrgStatus       @default(PENDING_VERIFICATION)
  trialEndsAt       DateTime?       @map("trial_ends_at")
  trialReminderSent DateTime?       @map("trial_reminder_sent")
  leadCap           Int             @default(10) @map("lead_cap") // free-plan cap, configurable by super admin
  planId            String?         @map("plan_id")
  settings          Json? // institution-type adaptive config, prefixes, thresholds
  onboardedAt       DateTime?       @map("onboarded_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  deletedAt         DateTime?       @map("deleted_at")
  centerCategory    String?         @map("center_category")
  isDummy           Boolean         @default(false) @map("is_dummy")

  plan                  Plan?                    @relation(fields: [planId], references: [id])
  branches              Branch[]
  users                 User[]
  roleAssignments       UserRoleAssignment[]
  organizationModules   OrganizationModule[]
  auditLogs             AuditLog[]
  apiKeys               ApiKey[]
  domains               OrgDomain[]
  notificationQueue     NotificationQueue[]
  subscriptions         Subscription[]
  transactions          Transaction[]
  schools               School[]
  parentEnquiries       ParentEnquiry[]
  parentApplications    ParentApplication[]
  waitlistEntries       WaitlistEntry[]
  openDayEvents         OpenDayEvent[]
  schoolReviews         SchoolReview[]
  reviewResponses       ReviewResponse[]
  academicYears         AcademicYear[]
  leads                 Lead[]
  admissions            Admission[]
  admissionStages       AdmissionStage[]
  admissionCapacities   AdmissionCapacity[]
  students              Student[]
  studentBatches        StudentBatch[]
  siblingLinks          SiblingLink[]
  feePlans              FeePlan[]
  feePlanTemplates      FeePlanTemplate[]
  invoices              Invoice[]
  payments              Payment[]
  concessions           Concession[]
  events                Event[]
  campaigns             Campaign[]
  notifications         Notification[]
  notificationPrefs     NotificationPreference[]
  counsellorTargets     CounsellorTarget[]
  communicationLogs     CommunicationLog[]
  terms                 Term[]
  courses               Course[]
  courseEnrollments     CourseEnrollment[]
  whatsappTemplates     WhatsappTemplate[]
  paymentGatewayConfigs PaymentGatewayConfig[]
  gatewayOrders         GatewayOrder[]
  refunds               Refund[]
  guardianLinks         StudentGuardianLink[]
  ledgerEntries         LedgerEntry[]
  messageWallets        MessageWallet[]
  messagingProviders    MessagingProviderConfig[]

  @@index([status])
  @@index([institutionType])
  @@index([planId])
  @@map("organizations")
  @@schema("platform")
}

/// Physical/operational branch. Every org auto-gets one default branch.
model Branch {
  id          String    @id @default(cuid())
  orgId       String    @map("org_id")
  name        String
  isDefault   Boolean   @default(false) @map("is_default")
  code        String?
  addressLine String?   @map("address_line")
  city        String?
  state       String?
  pincode     String?
  phone       String?
  email       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  organization        Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userBranchAccess    UserBranchAccess[]
  leads               Lead[]
  admissions          Admission[]
  admissionCapacities AdmissionCapacity[]
  students            Student[]
  studentBatches      StudentBatch[]
  feePlans            FeePlan[]
  invoices            Invoice[]
  payments            Payment[]
  events              Event[]
  campaigns           Campaign[]
  counsellorTargets   CounsellorTarget[]

  @@index([orgId])
  @@map("branches")
  @@schema("platform")
}

/// All authenticated actors (platform staff + org staff + parents-as-users).
model User {
  id          String     @id @default(cuid())
  orgId       String?    @map("org_id") // null for platform-level users (SUPER_ADMIN etc.)
  email       String?    @unique
  phone       String?    @unique
  name        String
  status      UserStatus @default(ACTIVE)
  pinHash     String?    @map("pin_hash") // optional PIN for trusted devices
  pinSetAt    DateTime?  @map("pin_set_at")
  lastLoginAt DateTime?  @map("last_login_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")

  organization       Organization?            @relation(fields: [orgId], references: [id])
  branchAccess       UserBranchAccess[]
  roleAssignments    UserRoleAssignment[]
  assignedLeads      Lead[]                   @relation("LeadCounsellor")
  assignedAdmissions Admission[]              @relation("AdmissionCounsellor")
  counsellorTargets  CounsellorTarget[]
  communicationLogs  CommunicationLog[]
  notificationPrefs  NotificationPreference[]
  parent             Parent?
  studentActivities  StudentActivity[]        @relation("StudentActivityPerformedBy")

  @@unique([orgId, email])
  @@index([orgId])
  @@index([phone])
  @@map("users")
  @@schema("platform")
}

/// Per-branch access grant; a user may hold a different role per branch.
model UserBranchAccess {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  branchId  String   @map("branch_id")
  role      UserRole
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, branchId])
  @@index([branchId])
  @@map("user_branch_access")
  @@schema("platform")
}

/// Global catalog of CRM feature modules (one row per module slug).
model Module {
  id          String   @id @default(cuid())
  slug        String   @unique // lead_management, admission_management, ...
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organizationModules OrganizationModule[]

  @@map("modules")
  @@schema("platform")
}

/// Per-org enablement of a module, toggled by Vidhyaan super admin.
model OrganizationModule {
  id         String    @id @default(cuid())
  orgId      String    @map("org_id")
  moduleId   String    @map("module_id")
  enabled    Boolean   @default(false)
  config     Json? // per-module limits/config (e.g., lead cap override)
  enabledAt  DateTime? @map("enabled_at")
  disabledAt DateTime? @map("disabled_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  module       Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([orgId, moduleId])
  @@index([orgId])
  @@map("organization_modules")
  @@schema("platform")
}

/// Append-only audit trail (3-5 year retention).
model AuditLog {
  id         String      @id @default(cuid())
  orgId      String?     @map("org_id")
  userId     String?     @map("user_id") // soft reference
  action     AuditAction
  entityType String      @map("entity_type")
  entityId   String?     @map("entity_id")
  before     Json?
  after      Json?
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  createdAt  DateTime    @default(now()) @map("created_at")

  organization Organization? @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
  @@schema("platform")
}

/// Logs from the school-data scraping/ingestion pipeline.
model ScrapingLog {
  id         String         @id @default(cuid())
  source     String
  targetUrl  String?        @map("target_url")
  schoolId   String?        @map("school_id") // soft reference into marketplace.schools
  status     ScrapingStatus @default(PENDING)
  recordsIn  Int            @default(0) @map("records_in")
  recordsOut Int            @default(0) @map("records_out")
  error      String?
  payload    Json?
  createdAt  DateTime       @default(now()) @map("created_at")

  @@index([status])
  @@index([schoolId])
  @@index([createdAt])
  @@map("scraping_logs")
  @@schema("platform")
}

/// API key for the public read-only API (gated by api_access). Max 3 active/org.
model ApiKey {
  id          String    @id @default(cuid())
  orgId       String    @map("org_id")
  name        String
  prefix      String // display hint, e.g. vk_live_ab12
  hash        String    @unique // sha256(token)
  ipWhitelist String[]  @default([]) @map("ip_whitelist")
  lastUsedAt  DateTime? @map("last_used_at")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([hash])
  @@map("api_keys")
  @@schema("platform")
}

/// Issued OTP record (hash only). Backs verification, brute-force lock + audit.
model OtpCode {
  id         String     @id @default(cuid())
  identifier String // phone or email
  channel    OtpChannel
  purpose    OtpPurpose
  codeHash   String     @map("code_hash")
  attempts   Int        @default(0)
  consumedAt DateTime?  @map("consumed_at")
  expiresAt  DateTime   @map("expires_at")
  ipAddress  String?    @map("ip_address")
  createdAt  DateTime   @default(now()) @map("created_at")

  @@index([identifier])
  @@index([expiresAt])
  @@map("otp_codes")
  @@schema("platform")
}

/// Custom domain mapping for an org (custom_domain module).
model OrgDomain {
  id         String       @id @default(cuid())
  orgId      String       @map("org_id")
  domain     String       @unique
  status     DomainStatus @default(PENDING)
  dnsRecords Json?        @map("dns_records")
  verifiedAt DateTime?    @map("verified_at")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("org_domains")
  @@schema("platform")
}

model LocationCache {
  id          String   @id @default(cuid())
  latRounded  String   @map("lat_rounded")
  lngRounded  String   @map("lng_rounded")
  city        String
  state       String?
  country     String   @default("India")
  pincode     String?
  fullAddress String?  @map("full_address")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([latRounded, lngRounded])
  @@index([city])
  @@map("location_cache")
  @@schema("platform")
}

// ============================================================================
// SCHEMA: marketplace — parent-facing discovery
// ============================================================================

/// Public school/learning-center listing. May be claimed (org_id set) or scraped (org_id null).
model School {
  id                      String             @id @default(cuid())
  orgId                   String?            @map("org_id") // set when claimed by an organization
  name                    String
  slug                    String             @unique
  institutionType         InstitutionType    @map("institution_type")
  description             String?
  verificationStatus      VerificationStatus @default(UNCLAIMED) @map("verification_status")
  isVerified              Boolean            @default(false) @map("is_verified")
  profileCompletion       Int                @default(0) @map("profile_completion") // 0-100
  rankingScore            Int                @default(0) @map("ranking_score") // 0-100 search score
  avgRating               Float              @default(0) @map("avg_rating")
  reviewCount             Int                @default(0) @map("review_count")
  responseRatePct         Int?               @map("response_rate_pct")
  avgResponseHours        Int?               @map("avg_response_hours")
  admissionOpen           Boolean            @default(false) @map("admission_open")
  googlePlaceId           String?            @map("google_place_id")
  dataSource              DataSource         @default(SCRAPED) @map("data_source")
  qualityScore            Int                @default(0) @map("quality_score") // data-completeness/quality 0-100
  claimedAt               DateTime?          @map("claimed_at")
  verifiedAt              DateTime?          @map("verified_at")
  rejectionReason         String?            @map("rejection_reason")
  createdAt               DateTime           @default(now()) @map("created_at")
  updatedAt               DateTime           @updatedAt @map("updated_at")
  deletedAt               DateTime?          @map("deleted_at")
  centerCategory          String?            @map("center_category")
  isDummy                 Boolean            @default(false) @map("is_dummy")
  examFocus               String[]           @map("exam_focus")
  mediumOfInstructionList String[]           @map("medium_of_instruction_list")

  // For Learning Centers
  trialClassAvailable  Boolean  @default(false) @map("trial_class_available")
  enrollmentStatus     String   @default("OPEN") @map("enrollment_status")
  ageGroupMin          Int?     @map("age_group_min")
  ageGroupMax          Int?     @map("age_group_max")
  monthlyFeeMin        Int?     @map("monthly_fee_min")
  monthlyFeeMax        Int?     @map("monthly_fee_max")
  activityTypes        String[] @map("activity_types")
  homeVisitAvailable   Boolean  @default(false) @map("home_visit_available")
  batchCount           Int      @default(0) @map("batch_count")
  enrolledStudentCount Int      @default(0) @map("enrolled_student_count")

  // Profile data fields
  establishedYear     Int?      @map("established_year")
  totalStudents       Int?      @map("total_students")
  totalTeachers       Int?      @map("total_teachers")
  mediumOfInstruction String?   @map("medium_of_instruction")
  schoolType          String?   @map("school_type")
  gender              String?   @map("gender")
  gradesOffered       String?   @map("grades_offered")
  academicYear        String?   @map("academic_year")
  admissionDeadline   DateTime? @map("admission_deadline")
  admissionFormLink   String?   @map("admission_form_link")
  isManagedBySchool   Boolean   @default(false) @map("is_managed_by_school")
  isPublished         Boolean   @default(false) @map("is_published")
  isClaimed           Boolean   @default(false) @map("is_claimed")
  viewCount           Int       @default(0) @map("view_count")
  enquiryCount        Int       @default(0) @map("enquiry_count")

  organization    Organization?         @relation(fields: [orgId], references: [id])
  locations       SchoolLocation[]
  contacts        SchoolContact[]
  media           SchoolMedia[]
  facilities      SchoolFacility[]
  feeRanges       SchoolFeeRange[]
  affiliations    SchoolAffiliation[]
  accreditations  SchoolAccreditation[]
  hours           SchoolHours[]
  enquiries       ParentEnquiry[]
  applications    ParentApplication[]
  bookmarks       ParentBookmark[]
  views           SchoolView[]
  reviews         SchoolReview[]
  waitlistEntries WaitlistEntry[]
  openDayEvents   OpenDayEvent[]
  instructors     Instructor[]
  batchSchedules  BatchSchedule[]
  trialBookings   TrialClassBooking[]

  @@index([orgId])
  @@index([institutionType])
  @@index([isVerified])
  @@index([rankingScore])
  @@map("schools")
  @@schema("marketplace")
}

/// Geo + address record for a school (supports multiple campuses).
model SchoolLocation {
  id          String    @id @default(cuid())
  schoolId    String    @map("school_id")
  orgId       String?   @map("org_id")
  label       String?
  addressLine String?   @map("address_line")
  city        String?
  state       String?
  pincode     String?
  latitude    Float?
  longitude   Float?
  isPrimary   Boolean   @default(false) @map("is_primary")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([city])
  @@index([pincode])
  @@index([addressLine(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("school_locations")
  @@schema("marketplace")
}

/// Public contact channels for a school.
model SchoolContact {
  id        String    @id @default(cuid())
  schoolId  String    @map("school_id")
  orgId     String?   @map("org_id")
  type      String // phone, email, website, whatsapp
  value     String
  isPrimary Boolean   @default(false) @map("is_primary")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("school_contacts")
  @@schema("marketplace")
}

/// Images/videos on a school profile (free plan capped at 3 images).
model SchoolMedia {
  id        String    @id @default(cuid())
  schoolId  String    @map("school_id")
  orgId     String?   @map("org_id")
  type      String // image, video
  url       String
  caption   String?
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("school_media")
  @@schema("marketplace")
}

/// Facility/amenity tags for a school.
model SchoolFacility {
  id        String   @id @default(cuid())
  schoolId  String   @map("school_id")
  orgId     String?  @map("org_id")
  name      String
  category  String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("school_facilities")
  @@schema("marketplace")
}

/// Published fee ranges shown in discovery (not the CRM fee engine).
model SchoolFeeRange {
  id         String   @id @default(cuid())
  schoolId   String   @map("school_id")
  orgId      String?  @map("org_id")
  gradeLabel String   @map("grade_label")
  minAmount  Decimal  @map("min_amount") @db.Decimal(12, 2)
  maxAmount  Decimal  @map("max_amount") @db.Decimal(12, 2)
  frequency  String? // annual, monthly
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("school_fee_ranges")
  @@schema("marketplace")
}

/// Board/affiliation details for a school (e.g., CBSE, ICSE, State).
model SchoolAffiliation {
  id            String    @id @default(cuid())
  schoolId      String    @map("school_id")
  orgId         String?   @map("org_id")
  board         String
  affiliationNo String?   @map("affiliation_no")
  validTill     DateTime? @map("valid_till")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("school_affiliation")
  @@schema("marketplace")
}

/// Accreditations/awards/recognitions for a school.
model SchoolAccreditation {
  id        String    @id @default(cuid())
  schoolId  String    @map("school_id")
  orgId     String?   @map("org_id")
  name      String
  issuedBy  String?   @map("issued_by")
  issuedAt  DateTime? @map("issued_at")
  validTill DateTime? @map("valid_till")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("school_accreditation")
  @@schema("marketplace")
}

/// Weekly operating hours for a school (display + "open now" + ranking signal).
model SchoolHours {
  id        String   @id @default(cuid())
  schoolId  String   @map("school_id")
  orgId     String?  @map("org_id")
  dayOfWeek Int      @map("day_of_week") // 0=Sun .. 6=Sat
  openTime  String?  @map("open_time") // HH:mm
  closeTime String?  @map("close_time") // HH:mm
  isClosed  Boolean  @default(false) @map("is_closed")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, dayOfWeek])
  @@index([schoolId])
  @@map("school_hours")
  @@schema("marketplace")
}

model Instructor {
  id              String   @id @default(cuid())
  orgId           String   @map("org_id")
  schoolId        String   @map("school_id")
  name            String
  qualification   String?
  specialization  String?
  experienceYears Int?     @map("experience_years")
  photoUrl        String?  @map("photo_url")
  bio             String?
  isActive        Boolean  @default(true) @map("is_active")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([orgId])
  @@map("instructors")
  @@schema("marketplace")
}

model BatchSchedule {
  id              String    @id @default(cuid())
  orgId           String    @map("org_id")
  schoolId        String    @map("school_id")
  activityName    String    @map("activity_name")
  batchName       String?   @map("batch_name")
  daysOfWeek      String[]  @map("days_of_week")
  startTime       String    @map("start_time")
  endTime         String    @map("end_time")
  ageGroupMin     Int?      @map("age_group_min")
  ageGroupMax     Int?      @map("age_group_max")
  monthlyFee      Int       @default(0) @map("monthly_fee")
  yearlyFee       Int?      @map("yearly_fee")
  registrationFee Int       @default(0) @map("registration_fee")
  capacity        Int       @default(20)
  enrolledCount   Int       @default(0) @map("enrolled_count")
  gender          String    @default("ALL")
  isActive        Boolean   @default(true) @map("is_active")
  isFull          Boolean   @default(false) @map("is_full")
  startDate       DateTime? @map("start_date")
  endDate         DateTime? @map("end_date")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  school        School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  trialBookings TrialClassBooking[]

  @@index([schoolId])
  @@index([orgId])
  @@map("batch_schedules")
  @@schema("marketplace")
}

model TrialClassBooking {
  id              String    @id @default(cuid())
  orgId           String    @map("org_id")
  schoolId        String    @map("school_id")
  batchScheduleId String?   @map("batch_schedule_id")
  parentName      String    @map("parent_name")
  phone           String
  email           String?
  childName       String    @map("child_name")
  childAge        Int?      @map("child_age")
  preferredDate   DateTime? @map("preferred_date")
  activityType    String?   @map("activity_type")
  message         String?
  status          String    @default("PENDING")
  confirmedAt     DateTime? @map("confirmed_at")
  cancelledAt     DateTime? @map("cancelled_at")
  notes           String?
  ipAddress       String?   @map("ip_address")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  batchSchedule BatchSchedule? @relation(fields: [batchScheduleId], references: [id])

  @@index([schoolId])
  @@index([orgId])
  @@index([status])
  @@index([createdAt])
  @@map("trial_class_bookings")
  @@schema("marketplace")
}

/// Parent account (external actor; mobile-OTP first). Not tenant-scoped.
model Parent {
  id        String    @id @default(cuid())
  phone     String    @unique
  email     String?   @unique
  name      String?
  city      String?
  pinHash   String?   @map("pin_hash")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  kids            KidProfile[]
  enquiries       ParentEnquiry[]
  applications    ParentApplication[]
  bookmarks       ParentBookmark[]
  reviews         SchoolReview[]
  waitlistEntries WaitlistEntry[]
  openDayRsvps    OpenDayRsvp[]
  guardianLinks   StudentGuardianLink[]
  userId          String?               @unique @map("user_id")
  user            User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone])
  @@map("parents")
  @@schema("marketplace")
}

/// A child belonging to a parent (used to pre-fill enquiries/applications).
model KidProfile {
  id          String    @id @default(cuid())
  parentId    String    @map("parent_id")
  name        String
  dateOfBirth DateTime? @map("date_of_birth")
  gender      Gender?
  gradeSought String?   @map("grade_sought")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  parent Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId])
  @@map("kids_profiles")
  @@schema("marketplace")
}

/// Discovery-side enquiry from a parent to a school (becomes a CRM lead).
model ParentEnquiry {
  id             String        @id @default(cuid())
  orgId          String?       @map("org_id")
  schoolId       String        @map("school_id")
  parentId       String        @map("parent_id")
  kidName        String?       @map("kid_name")
  gradeSought    String?       @map("grade_sought")
  message        String?
  status         EnquiryStatus @default(NEW)
  leadId         String?       @map("lead_id") // soft link to crm.leads once created
  type           String?       @default("ENQUIRY") // ENQUIRY, VISIT_REQUEST
  preferredDate  DateTime?     @map("preferred_date")
  preferredTime  String?       @map("preferred_time")
  visitorCount   Int?          @map("visitor_count")
  lastFollowUpAt DateTime?     @map("last_follow_up_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  organization Organization? @relation(fields: [orgId], references: [id])
  school       School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  parent       Parent        @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([schoolId])
  @@index([parentId])
  @@index([status])
  @@map("parent_enquiries")
  @@schema("marketplace")
}

/// Formal admission application submitted by a parent and tracked by them.
model ParentApplication {
  id          String            @id @default(cuid())
  orgId       String?           @map("org_id")
  schoolId    String            @map("school_id")
  parentId    String            @map("parent_id")
  kidName     String            @map("kid_name")
  gradeSought String?           @map("grade_sought")
  status      ApplicationStatus @default(SUBMITTED)
  admissionId String?           @map("admission_id") // soft link to crm.admissions
  submittedAt DateTime          @default(now()) @map("submitted_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  deletedAt   DateTime?         @map("deleted_at")

  organization Organization? @relation(fields: [orgId], references: [id])
  school       School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  parent       Parent        @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([schoolId])
  @@index([parentId])
  @@index([status])
  @@map("parent_applications")
  @@schema("marketplace")
}

/// Parent's saved/bookmarked schools. Parent-owned; not tenant-scoped.
model ParentBookmark {
  id        String   @id @default(cuid())
  parentId  String   @map("parent_id")
  schoolId  String   @map("school_id")
  createdAt DateTime @default(now()) @map("created_at")

  parent Parent @relation(fields: [parentId], references: [id], onDelete: Cascade)
  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([parentId, schoolId])
  @@index([schoolId])
  @@map("parent_bookmarks")
  @@schema("marketplace")
}

/// Profile view analytics (drives ranking + dashboards).
model SchoolView {
  id        String   @id @default(cuid())
  schoolId  String   @map("school_id")
  orgId     String?  @map("org_id")
  parentId  String?  @map("parent_id") // soft reference
  source    String?
  ipHash    String?  @map("ip_hash")
  createdAt DateTime @default(now()) @map("created_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([createdAt])
  @@map("school_views")
  @@schema("marketplace")
}

/// Parent review of a school (verified parents only; auto-publish).
model SchoolReview {
  id                   String       @id @default(cuid())
  schoolId             String       @map("school_id")
  orgId                String?      @map("org_id")
  parentId             String       @map("parent_id")
  rating               Int // 1-5 overall
  ratingAcademics      Int?         @map("rating_academics") // 1-5
  ratingFaculty        Int?         @map("rating_faculty") // 1-5
  ratingInfrastructure Int?         @map("rating_infrastructure") // 1-5
  ratingSafety         Int?         @map("rating_safety") // 1-5
  ratingActivities     Int?         @map("rating_activities") // 1-5
  ratingValue          Int?         @map("rating_value") // 1-5 value for money
  title                String?
  body                 String?
  status               ReviewStatus @default(PUBLISHED)
  flagReason           String?      @map("flag_reason")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")
  deletedAt            DateTime?    @map("deleted_at")

  school       School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  organization Organization?    @relation(fields: [orgId], references: [id])
  parent       Parent           @relation(fields: [parentId], references: [id], onDelete: Cascade)
  responses    ReviewResponse[]

  @@index([schoolId])
  @@index([parentId])
  @@index([status])
  @@map("school_reviews")
  @@schema("marketplace")
}

/// Threaded responses to a review (school + parent reply chain).
model ReviewResponse {
  id         String    @id @default(cuid())
  reviewId   String    @map("review_id")
  orgId      String?   @map("org_id")
  authorType String    @map("author_type") // SCHOOL, PARENT, VIDHYAAN
  authorId   String?   @map("author_id") // soft reference
  body       String
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  review       SchoolReview  @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [orgId], references: [id])

  @@index([reviewId])
  @@map("review_responses")
  @@schema("marketplace")
}

/// Parent waitlist entry when a grade/seat is full.
model WaitlistEntry {
  id         String         @id @default(cuid())
  orgId      String         @map("org_id")
  schoolId   String         @map("school_id")
  parentId   String         @map("parent_id")
  gradeLabel String         @map("grade_label")
  position   Int?
  status     WaitlistStatus @default(WAITING)
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")
  deletedAt  DateTime?      @map("deleted_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  parent       Parent       @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([schoolId])
  @@index([status])
  @@map("waitlist_entries")
  @@schema("marketplace")
}

/// Public open-day / campus-visit event published by a school.
model OpenDayEvent {
  id          String    @id @default(cuid())
  orgId       String    @map("org_id")
  schoolId    String    @map("school_id")
  title       String
  description String?
  startsAt    DateTime  @map("starts_at")
  endsAt      DateTime? @map("ends_at")
  venue       String?
  capacity    Int?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  school       School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  rsvps        OpenDayRsvp[]

  @@index([orgId])
  @@index([schoolId])
  @@index([startsAt])
  @@map("open_day_events")
  @@schema("marketplace")
}

/// Parent RSVP to an open-day event. Parent-owned; not tenant-scoped.
model OpenDayRsvp {
  id        String     @id @default(cuid())
  eventId   String     @map("event_id")
  parentId  String     @map("parent_id")
  status    RsvpStatus @default(GOING)
  guests    Int        @default(1)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  event  OpenDayEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  parent Parent       @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([eventId, parentId])
  @@index([parentId])
  @@map("open_day_rsvp")
  @@schema("marketplace")
}

// ============================================================================
// SCHEMA: crm — school CRM product
// ============================================================================

/// Org-scoped academic/financial year; exactly one ACTIVE per org.
model AcademicYear {
  id        String             @id @default(cuid())
  orgId     String             @map("org_id")
  name      String // e.g., 2025-26
  type      AcademicYearType
  startDate DateTime           @map("start_date")
  endDate   DateTime           @map("end_date")
  status    AcademicYearStatus @default(UPCOMING)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  organization        Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  leads               Lead[]
  admissions          Admission[]
  admissionCapacities AdmissionCapacity[]
  students            Student[]
  studentBatches      StudentBatch[]
  feePlans            FeePlan[]
  invoices            Invoice[]
  payments            Payment[]
  events              Event[]
  campaigns           Campaign[]
  counsellorTargets   CounsellorTarget[]
  terms               Term[]

  @@unique([orgId, name])
  @@index([orgId])
  @@index([status])
  @@map("academic_years")
  @@schema("crm")
}

/// Admission lead. Auto-created from Vidhyaan enquiries or manual entry.
model Lead {
  id               String       @id @default(cuid())
  orgId            String       @map("org_id")
  branchId         String?      @map("branch_id")
  academicYearId   String?      @map("academic_year_id")
  leadCode         String       @map("lead_code") // LD-YYYY-XXXXX
  parentName       String       @map("parent_name")
  phone            String
  email            String?
  kidName          String?      @map("kid_name")
  gradeSought      String?      @map("grade_sought")
  source           LeadSource   @default(OTHER)
  status           LeadStatus   @default(NEW)
  priority         LeadPriority @default(MEDIUM)
  assignedToId     String?      @map("assigned_to_id")
  enquiryId        String?      @map("enquiry_id") // soft link to marketplace.parent_enquiries
  lostReason       String?      @map("lost_reason")
  firstContactedAt DateTime?    @map("first_contacted_at") // drives response-rate metric
  nextFollowUpAt   DateTime?    @map("next_follow_up_at")
  createdById      String?      @map("created_by_id") // soft reference
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  deletedAt        DateTime?    @map("deleted_at")

  childAge         Int?      @map("child_age")
  currentSchool    String?   @map("current_school")
  expectedJoinDate DateTime? @map("expected_join_date")
  siblingInSchool  Boolean?  @default(false) @map("sibling_in_school")
  course           String?
  batch            String?
  studentAge       String?   @map("student_age")
  startDate        DateTime? @map("start_date")

  organization Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch       Branch?        @relation(fields: [branchId], references: [id])
  academicYear AcademicYear?  @relation(fields: [academicYearId], references: [id])
  assignedTo   User?          @relation("LeadCounsellor", fields: [assignedToId], references: [id])
  activities   LeadActivity[]
  admissions   Admission[]

  @@unique([orgId, leadCode])
  @@index([orgId, createdAt])
  @@index([orgId, status])
  @@index([orgId, assignedToId])
  @@index([orgId, phone])
  @@index([branchId])
  @@index([academicYearId])
  @@map("leads")
  @@schema("crm")
}

/// Timeline entry on a lead (notes, calls, status changes, etc.). Dependent child.
model LeadActivity {
  id             String       @id @default(cuid())
  orgId          String       @map("org_id")
  branchId       String?      @map("branch_id")
  academicYearId String?      @map("academic_year_id")
  leadId         String       @map("lead_id")
  type           ActivityType
  summary        String
  metadata       Json?
  performedById  String?      @map("performed_by_id") // soft reference
  createdAt      DateTime     @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([orgId, leadId, createdAt])
  @@index([type])
  @@map("lead_activities")
  @@schema("crm")
}

/// Org-defined custom field definitions for leads.
model LeadCustomField {
  id        String          @id @default(cuid())
  orgId     String          @map("org_id")
  label     String
  key       String
  type      CustomFieldType
  options   Json? // for DROPDOWN
  required  Boolean         @default(false)
  sortOrder Int             @default(0) @map("sort_order")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@unique([orgId, key])
  @@index([orgId])
  @@map("lead_custom_fields")
  @@schema("crm")
}

/// Admission record progressing through org-configurable pipeline stages.
model Admission {
  id              String          @id @default(cuid())
  orgId           String          @map("org_id")
  branchId        String?         @map("branch_id")
  academicYearId  String?         @map("academic_year_id")
  admissionCode   String          @map("admission_code") // ADM-YYYY-XXXXX
  leadId          String?         @map("lead_id")
  stageId         String?         @map("stage_id")
  status          AdmissionStatus @default(IN_PROGRESS)
  applicantName   String          @map("applicant_name")
  parentName      String?         @map("parent_name")
  gradeSought     String?         @map("grade_sought")
  phone           String?
  email           String?
  assignedToId    String?         @map("assigned_to_id")
  rejectionReason String?         @map("rejection_reason")
  decidedAt       DateTime?       @map("decided_at")
  createdById     String?         @map("created_by_id") // soft reference
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")
  /// Admitted records cannot be deleted (they anchor student records and
  /// reporting); archiving hides them from active views instead.
  archivedAt      DateTime?       @map("archived_at")

  organization Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch       Branch?             @relation(fields: [branchId], references: [id])
  academicYear AcademicYear?       @relation(fields: [academicYearId], references: [id])
  lead         Lead?               @relation(fields: [leadId], references: [id])
  stage        AdmissionStage?     @relation(fields: [stageId], references: [id])
  assignedTo   User?               @relation("AdmissionCounsellor", fields: [assignedToId], references: [id])
  activities   AdmissionActivity[]
  documents    AdmissionDocument[]
  student      Student?

  @@unique([orgId, admissionCode])
  @@index([orgId, createdAt])
  @@index([orgId, status])
  @@index([orgId, stageId])
  @@index([orgId, assignedToId])
  @@index([branchId])
  @@index([academicYearId])
  @@map("admissions")
  @@schema("crm")
}

/// Org-configurable pipeline stage (School default 8, LC default 4).
model AdmissionStage {
  id              String    @id @default(cuid())
  orgId           String    @map("org_id")
  name            String
  sortOrder       Int       @map("sort_order")
  isWon           Boolean   @default(false) @map("is_won")
  isLost          Boolean   @default(false) @map("is_lost")
  requiresDocs    Boolean   @default(false) @map("requires_docs")
  requiresPayment Boolean   @default(false) @map("requires_payment")
  color           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  admissions   Admission[]

  @@unique([orgId, sortOrder])
  @@index([orgId])
  @@map("admission_stages")
  @@schema("crm")
}

/// Timeline entry on an admission. Dependent child.
model AdmissionActivity {
  id             String       @id @default(cuid())
  orgId          String       @map("org_id")
  branchId       String?      @map("branch_id")
  academicYearId String?      @map("academic_year_id")
  admissionId    String       @map("admission_id")
  type           ActivityType
  summary        String
  metadata       Json?
  performedById  String?      @map("performed_by_id") // soft reference
  createdAt      DateTime     @default(now()) @map("created_at")

  admission Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)

  @@index([orgId, admissionId, createdAt])
  @@map("admission_activities")
  @@schema("crm")
}

/// Document uploaded against an admission (ClamAV + Vision scanned). Dependent child.
model AdmissionDocument {
  id           String               @id @default(cuid())
  orgId        String               @map("org_id")
  admissionId  String               @map("admission_id")
  name         String
  type         String // PDF, JPG, PNG
  url          String // Org/Student/filename in DO Spaces
  sizeBytes    Int?                 @map("size_bytes")
  scanStatus   DocumentReviewStatus @default(PENDING) @map("scan_status")
  isAadhaar    Boolean              @default(false) @map("is_aadhaar") // max 1yr retention
  expiresAt    DateTime?            @map("expires_at")
  uploadedById String?              @map("uploaded_by_id") // soft reference
  createdAt    DateTime             @default(now()) @map("created_at")
  deletedAt    DateTime?            @map("deleted_at")

  admission Admission @relation(fields: [admissionId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([admissionId])
  @@index([scanStatus])
  @@map("admission_documents")
  @@schema("crm")
}

/// Seat capacity per grade per year; drives auto-close + waitlist trigger.
model AdmissionCapacity {
  id             String   @id @default(cuid())
  orgId          String   @map("org_id")
  branchId       String?  @map("branch_id")
  academicYearId String   @map("academic_year_id")
  gradeLabel     String   @map("grade_label")
  totalSeats     Int      @map("total_seats")
  filledSeats    Int      @default(0) @map("filled_seats")
  autoClose      Boolean  @default(true) @map("auto_close")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  @@unique([orgId, academicYearId, branchId, gradeLabel])
  @@index([orgId])
  @@index([academicYearId])
  @@map("admission_capacity")
  @@schema("crm")
}

/// Enrolled student. Auto-created on admission/lead convert.
model Student {
  id                    String        @id @default(cuid())
  orgId                 String        @map("org_id")
  branchId              String?       @map("branch_id")
  academicYearId        String?       @map("academic_year_id")
  studentCode           String        @map("student_code") // STU-YYYY-XXXXX
  rollNumber            String?       @map("roll_number")
  section               String?
  admissionId           String?       @unique @map("admission_id")
  batchId               String?       @map("batch_id")
  name                  String
  gender                Gender?
  dateOfBirth           DateTime?     @map("date_of_birth")
  gradeLabel            String?       @map("grade_label")
  guardianName          String?       @map("guardian_name")
  guardianPhone         String?       @map("guardian_phone")
  guardianEmail         String?       @map("guardian_email")
  status                StudentStatus @default(ACTIVE)
  alumniSince           DateTime?     @map("alumni_since")
  portalAccessRevokedAt DateTime?     @map("portal_access_revoked_at") // alumni: removed 60 days after
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  deletedAt             DateTime?     @map("deleted_at")

  organization      Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch            Branch?               @relation(fields: [branchId], references: [id])
  academicYear      AcademicYear?         @relation(fields: [academicYearId], references: [id])
  admission         Admission?            @relation(fields: [admissionId], references: [id])
  batch             StudentBatch?         @relation(fields: [batchId], references: [id])
  invoices          Invoice[]
  payments          Payment[]
  concessions       Concession[]
  siblingLinksA     SiblingLink[]         @relation("SiblingPrimary")
  siblingLinksB     SiblingLink[]         @relation("SiblingRelated")
  activities        StudentActivity[]
  courseEnrollments CourseEnrollment[]
  ledgerEntries     LedgerEntry[]
  guardianLinks     StudentGuardianLink[]

  @@unique([orgId, studentCode])
  @@index([orgId, createdAt])
  @@index([orgId, status])
  @@index([orgId, gradeLabel])
  @@index([orgId, gradeLabel, section])
  @@index([branchId])
  @@index([academicYearId])
  @@index([batchId])
  @@map("students")
  @@schema("crm")
}

model StudentActivity {
  id            String       @id @default(cuid())
  studentId     String       @map("student_id")
  type          ActivityType
  summary       String
  note          String?
  performedById String?      @map("performed_by_id")
  createdAt     DateTime     @default(now()) @map("created_at")

  student     Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  performedBy User?   @relation(name: "StudentActivityPerformedBy", fields: [performedById], references: [id])

  @@index([studentId])
  @@index([performedById])
  @@map("student_activities")
  @@schema("crm")
}

/// Org-defined custom field definitions for students.
model StudentCustomField {
  id        String          @id @default(cuid())
  orgId     String          @map("org_id")
  label     String
  key       String
  type      CustomFieldType
  options   Json?
  required  Boolean         @default(false)
  sortOrder Int             @default(0) @map("sort_order")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@unique([orgId, key])
  @@index([orgId])
  @@map("student_custom_fields")
  @@schema("crm")
}

/// Batch/cohort grouping (primarily Learning Centers).
model StudentBatch {
  id             String    @id @default(cuid())
  orgId          String    @map("org_id")
  branchId       String?   @map("branch_id")
  academicYearId String?   @map("academic_year_id")
  name           String
  programme      String?
  startDate      DateTime? @map("start_date")
  endDate        DateTime? @map("end_date")
  capacity       Int?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch       Branch?       @relation(fields: [branchId], references: [id])
  academicYear AcademicYear? @relation(fields: [academicYearId], references: [id])
  students     Student[]

  @@index([orgId])
  @@index([branchId])
  @@map("student_batches")
  @@schema("crm")
}

/// Links two students as siblings (drives sibling concessions/insights).
model SiblingLink {
  id        String   @id @default(cuid())
  orgId     String   @map("org_id")
  studentId String   @map("student_id")
  siblingId String   @map("sibling_id")
  relation  String? // brother, sister
  createdAt DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  student      Student      @relation("SiblingPrimary", fields: [studentId], references: [id], onDelete: Cascade)
  sibling      Student      @relation("SiblingRelated", fields: [siblingId], references: [id], onDelete: Cascade)

  @@unique([studentId, siblingId])
  @@index([orgId])
  @@index([siblingId])
  @@map("sibling_links")
  @@schema("crm")
}

/// Reusable fee structure template (org-level).
model FeePlanTemplate {
  id              String    @id @default(cuid())
  orgId           String    @map("org_id")
  name            String
  gradeLabel      String?   @map("grade_label")
  institutionType String?   @map("institution_type")
  structure       Json // array of { head, amount, frequency }
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  feePlans     FeePlan[]

  @@index([orgId])
  @@map("fee_plan_templates")
  @@schema("crm")
}

/// Applied fee plan instance (per grade/batch/year), basis for invoices.
model FeePlan {
  id             String       @id @default(cuid())
  orgId          String       @map("org_id")
  branchId       String?      @map("branch_id")
  academicYearId String?      @map("academic_year_id")
  templateId     String?      @map("template_id")
  name           String
  gradeLabel     String?      @map("grade_label")
  totalAmount    Decimal      @map("total_amount") @db.Decimal(12, 2)
  frequency      FeeFrequency @default(ANNUAL)
  structure      Json // line items
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  organization Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch       Branch?          @relation(fields: [branchId], references: [id])
  academicYear AcademicYear?    @relation(fields: [academicYearId], references: [id])
  template     FeePlanTemplate? @relation(fields: [templateId], references: [id])

  @@index([orgId])
  @@index([academicYearId])
  @@map("fee_plans")
  @@schema("crm")
}

/// Student fee invoice (INV-YYYY-XXXXX).
model Invoice {
  id             String        @id @default(cuid())
  orgId          String        @map("org_id")
  branchId       String?       @map("branch_id")
  academicYearId String?       @map("academic_year_id")
  invoiceNumber  String        @map("invoice_number") // INV-YYYY-XXXXX
  studentId      String        @map("student_id")
  totalAmount    Decimal       @map("total_amount") @db.Decimal(12, 2)
  paidAmount     Decimal       @default(0) @map("paid_amount") @db.Decimal(12, 2)
  lateFeeAmount  Decimal       @default(0) @map("late_fee_amount") @db.Decimal(12, 2)
  status         InvoiceStatus @default(UNPAID)
  invoiceType    InvoiceType   @default(ADHOC) @map("invoice_type")
  termId         String?       @map("term_id")
  courseId       String?       @map("course_id")
  dueDate        DateTime?     @map("due_date")
  scheduledDate  DateTime?     @map("scheduled_date")
  batchId        String?       @map("batch_id")
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  organization  Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch        Branch?        @relation(fields: [branchId], references: [id])
  academicYear  AcademicYear?  @relation(fields: [academicYearId], references: [id])
  student       Student        @relation(fields: [studentId], references: [id])
  term          Term?          @relation(fields: [termId], references: [id])
  course        Course?        @relation(fields: [courseId], references: [id])
  items         InvoiceItem[]
  payments      Payment[]
  concessions   Concession[]
  gatewayOrders GatewayOrder[]

  @@unique([orgId, invoiceNumber])
  @@index([orgId, createdAt])
  @@index([orgId, status])
  @@index([orgId, studentId])
  @@index([orgId, dueDate])
  @@index([orgId, invoiceType])
  @@index([termId])
  @@index([courseId])
  @@index([batchId])
  @@map("invoices")
  @@schema("crm")
}

/// Line item on an invoice. Dependent child.
model InvoiceItem {
  id        String   @id @default(cuid())
  orgId     String   @map("org_id")
  invoiceId String   @map("invoice_id")
  head      String // fee head name
  amount    Decimal  @db.Decimal(12, 2)
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([invoiceId])
  @@map("invoice_items")
  @@schema("crm")
}

/// Payment against an invoice (RCP-YYYY-XXXXX); partial payments allowed.
model Payment {
  id             String        @id @default(cuid())
  orgId          String        @map("org_id")
  branchId       String?       @map("branch_id")
  academicYearId String?       @map("academic_year_id")
  receiptNumber  String        @map("receipt_number") // RCP-YYYY-XXXXX
  invoiceId      String        @map("invoice_id")
  studentId      String?       @map("student_id")
  amount         Decimal       @db.Decimal(12, 2)
  method         PaymentMethod @default(RAZORPAY)
  status         PaymentStatus @default(PENDING)
  gatewayRef     String?       @map("gateway_ref") // Razorpay payment id
  gatewayOrderId String?       @map("gateway_order_id") // soft reference → billing.gateway_orders
  refundedAmount Decimal       @default(0) @map("refunded_amount") @db.Decimal(12, 2)
  instrumentNo   String?       @map("instrument_no") // cheque / DD number
  instrumentDate DateTime?     @map("instrument_date")
  bankName       String?       @map("bank_name")
  bankBranch     String?       @map("bank_branch")
  utrNumber      String?       @map("utr_number") // NEFT/RTGS/IMPS UTR
  clearedAt      DateTime?     @map("cleared_at") // cheque/DD/NEFT realization
  paidAt         DateTime?     @map("paid_at")
  createdById    String?       @map("created_by_id") // soft reference
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch       Branch?       @relation(fields: [branchId], references: [id])
  academicYear AcademicYear? @relation(fields: [academicYearId], references: [id])
  invoice      Invoice       @relation(fields: [invoiceId], references: [id])
  student      Student?      @relation(fields: [studentId], references: [id])
  refunds      Refund[]

  @@unique([orgId, receiptNumber])
  @@index([orgId, gatewayOrderId])
  @@index([orgId, paidAt])
  @@index([orgId, status])
  @@index([orgId, invoiceId])
  @@index([orgId, studentId])
  @@map("payments")
  @@schema("crm")
}

/// Manual fee concession/discount applied by school admin.
model Concession {
  id           String         @id @default(cuid())
  orgId        String         @map("org_id")
  studentId    String?        @map("student_id")
  invoiceId    String?        @map("invoice_id")
  type         ConcessionType
  value        Decimal        @db.Decimal(12, 2)
  reason       String?
  approvedById String?        @map("approved_by_id") // soft reference
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  deletedAt    DateTime?      @map("deleted_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  student      Student?     @relation(fields: [studentId], references: [id])
  invoice      Invoice?     @relation(fields: [invoiceId], references: [id])

  @@index([orgId])
  @@index([studentId])
  @@index([invoiceId])
  @@map("concessions")
  @@schema("crm")
}

/// Internal CRM event (calendar/meeting); distinct from public open days.
model Event {
  id             String      @id @default(cuid())
  orgId          String      @map("org_id")
  branchId       String?     @map("branch_id")
  academicYearId String?     @map("academic_year_id")
  title          String
  description    String?
  type           String? // OPEN_HOUSE, PTM, ANNUAL_DAY... / DEMO_CLASS, WORKSHOP... (institution-specific labels)
  capacity       Int?
  status         EventStatus @default(DRAFT) // DRAFT editable; PUBLISHED locked (cancel only)
  isPublished    Boolean     @default(false) @map("is_published") // deprecated by status; kept until phase 2 decides marketplace flag
  startsAt       DateTime    @map("starts_at")
  endsAt         DateTime?   @map("ends_at")
  location       String?
  meetingLink    String?     @map("meeting_link") // manual Zoom link Phase 1
  imageUrl       String?     @map("image_url") // S3 cover image
  publishedAt    DateTime?   @map("published_at")
  audience       String?     // ALL | PARENTS | LEADS (announce default)
  createdById    String?     @map("created_by_id") // soft reference
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  deletedAt      DateTime?   @map("deleted_at")

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch       Branch?       @relation(fields: [branchId], references: [id])
  academicYear AcademicYear? @relation(fields: [academicYearId], references: [id])
  rsvps         EventRsvp[]
  announcements EventAnnouncement[]

  @@index([orgId])
  @@index([startsAt])
  @@index([orgId, startsAt])
  @@map("events")
  @@schema("crm")
}

/// RSVP to an internal CRM event. Dependent child.
model EventRsvp {
  id           String     @id @default(cuid())
  orgId        String     @map("org_id")
  eventId      String     @map("event_id")
  attendeeType String     @map("attendee_type") // USER, PARENT, LEAD
  attendeeId   String?    @map("attendee_id") // soft reference
  status       RsvpStatus @default(GOING)
  createdAt    DateTime   @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([eventId])
  @@map("event_rsvp")
  @@schema("crm")
}

/// Audit of an event being announced through channels on publish.
model EventAnnouncement {
  id             String   @id @default(cuid())
  orgId          String   @map("org_id")
  eventId        String   @map("event_id")
  channels       String[] // PORTAL, EMAIL, WHATSAPP, SMS
  audience       String // ALL | PARENTS | LEADS
  recipientCount Int      @default(0) @map("recipient_count")
  sentCount      Int      @default(0) @map("sent_count")
  failedCount    Int      @default(0) @map("failed_count")
  createdById    String?  @map("created_by_id")
  createdAt      DateTime @default(now()) @map("created_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([eventId])
  @@map("event_announcements")
  @@schema("crm")
}

/// Bulk outreach campaign (Email/SMS/WhatsApp via MSG91/Resend).
model Campaign {
  id             String          @id @default(cuid())
  orgId          String          @map("org_id")
  branchId       String?         @map("branch_id")
  academicYearId String?         @map("academic_year_id")
  name           String
  channel        CampaignChannel
  status         CampaignStatus  @default(DRAFT)
  templateBody   String?         @map("template_body")
  /// Soft ref to crm.whatsapp_templates — chosen approved template for
  /// WHATSAPP campaigns (send builds positional params from it)
  whatsappTemplateId String?     @map("whatsapp_template_id")
  scheduledAt    DateTime?       @map("scheduled_at")
  sentAt         DateTime?       @map("sent_at")
  audienceFilter Json?           @map("audience_filter")
  stats          Json?
  createdById    String?         @map("created_by_id")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  deletedAt      DateTime?       @map("deleted_at")

  organization Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch       Branch?             @relation(fields: [branchId], references: [id])
  academicYear AcademicYear?       @relation(fields: [academicYearId], references: [id])
  recipients   CampaignRecipient[]

  @@index([orgId])
  @@index([status])
  @@map("campaigns")
  @@schema("crm")
}

model CampaignRecipient {
  id            String             @id @default(cuid())
  orgId         String             @map("org_id")
  campaignId    String             @map("campaign_id")
  recipientType String             @map("recipient_type")
  recipientId   String?            @map("recipient_id")
  name          String?
  phone         String?
  email         String?
  status        CampaignSendStatus @default(PENDING)
  sentAt        DateTime?          @map("sent_at")
  deliveredAt   DateTime?          @map("delivered_at")
  failureReason String?            @map("failure_reason")
  createdAt     DateTime           @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([campaignId])
  @@map("campaign_recipients")
  @@schema("crm")
}

/// DLT-approved WhatsApp templates saved by org admin.
model WhatsappTemplate {
  id               String           @id @default(cuid())
  orgId            String           @map("org_id")
  name             String
  msg91TemplateId  String           @map("msg91_template_id")
  body             String
  /// Meta language code of the approved template
  language         String           @default("en")
  /// Ordered variable tokens mapping to {{1}}..{{n}} in the approved
  /// template, e.g. ["parentName","amount"]. null = legacy
  /// single-blob-parameter mode.
  variables        Json?
  /// Which WhatsApp account this template lives on
  accountScope     WaAccountScope   @default(VIDHYAAN) @map("account_scope")
  /// Soft ref to billing.messaging_provider_configs when accountScope=OWN
  providerConfigId String?          @map("provider_config_id")
  status           WaTemplateStatus @default(DRAFT)
  /// Soft ref to platform.shared_whatsapp_templates when copied from catalog
  sharedTemplateId String?          @map("shared_template_id")
  createdById      String?          @map("created_by_id")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  deletedAt        DateTime?        @map("deleted_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([sharedTemplateId])
  @@map("whatsapp_templates")
  @@schema("crm")
}

enum WaAccountScope {
  VIDHYAAN
  OWN

  @@schema("crm")
}

enum WaTemplateStatus {
  DRAFT
  VERIFIED
  SYNCED

  @@schema("crm")
}

/// Platform-managed catalog of templates approved on Vidhyaan's shared
/// WhatsApp Business account. Orgs on the Vidhyaan account copy entries
/// from here instead of hand-typing MSG91 template names.
model SharedWhatsappTemplate {
  id              String    @id @default(cuid())
  name            String
  msg91TemplateId String    @map("msg91_template_id")
  language        String    @default("en")
  body            String
  /// Ordered variable tokens mapping to {{1}}..{{n}}
  variables       Json?
  isActive        Boolean   @default(true) @map("is_active")
  sortOrder       Int       @default(0) @map("sort_order")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  @@index([isActive])
  @@map("shared_whatsapp_templates")
  @@schema("platform")
}

/// In-app/outbound notification record.
model Notification {
  id            String              @id @default(cuid())
  orgId         String              @map("org_id")
  recipientType String              @map("recipient_type") // USER, PARENT
  recipientId   String?             @map("recipient_id") // soft reference
  channel       NotificationChannel @default(IN_APP)
  title         String
  body          String?
  data          Json?
  readAt        DateTime?           @map("read_at")
  deletedAt     DateTime?           @map("deleted_at")
  createdAt     DateTime            @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, recipientType, recipientId, createdAt])
  @@index([orgId, recipientType, recipientId, readAt])
  @@map("notifications")
  @@schema("crm")
}

/// Per-user notification channel preferences.
model NotificationPreference {
  id        String   @id @default(cuid())
  orgId     String   @map("org_id")
  userId    String   @map("user_id")
  category  String // fees, leads, admissions, system
  email     Boolean  @default(true)
  sms       Boolean  @default(false)
  whatsapp  Boolean  @default(false)
  inApp     Boolean  @default(true) @map("in_app")
  push      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([orgId])
  @@map("notification_preferences")
  @@schema("crm")
}

/// Counsellor performance target per period.
model CounsellorTarget {
  id               String   @id @default(cuid())
  orgId            String   @map("org_id")
  branchId         String?  @map("branch_id")
  academicYearId   String?  @map("academic_year_id")
  userId           String   @map("user_id")
  periodStart      DateTime @map("period_start")
  periodEnd        DateTime @map("period_end")
  leadTarget       Int      @default(0) @map("lead_target")
  conversionTarget Int      @default(0) @map("conversion_target")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  branch       Branch?       @relation(fields: [branchId], references: [id])
  academicYear AcademicYear? @relation(fields: [academicYearId], references: [id])
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([userId])
  @@map("counsellor_targets")
  @@schema("crm")
}

/// Immutable log of every outbound/inbound communication (1 year retention).
model CommunicationLog {
  id          String                 @id @default(cuid())
  orgId       String                 @map("org_id")
  userId      String?                @map("user_id")
  channel     NotificationChannel
  direction   CommunicationDirection
  entityType  String?                @map("entity_type") // LEAD, ADMISSION, INVOICE
  entityId    String?                @map("entity_id")
  contact     String // phone/email
  content     String?
  providerRef String?                @map("provider_ref")
  status      String?
  createdAt   DateTime               @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])

  @@index([orgId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("communication_logs")
  @@schema("crm")
}

/// Outbound notification queue — scheduled sends + delivery retries (worker drains it).
model NotificationQueue {
  id            String              @id @default(cuid())
  orgId         String              @map("org_id")
  channel       NotificationChannel
  recipientType String              @map("recipient_type") // USER, PARENT
  recipientId   String?             @map("recipient_id") // soft reference
  contact       String // phone/email
  payload       Json
  status        QueueStatus         @default(PENDING)
  scheduledFor  DateTime?           @map("scheduled_for")
  attempts      Int                 @default(0)
  lastError     String?             @map("last_error")
  sentAt        DateTime?           @map("sent_at")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([status, scheduledFor])
  @@map("notification_queue")
  @@schema("crm")
}

// ============================================================================
// SCHEMA: billing — subscriptions and revenue
// ============================================================================

/// Subscription plan catalog (canonical; referenced by platform.organizations).
model Plan {
  id             String    @id @default(cuid())
  slug           String    @unique // free, growth, pro, enterprise
  name           String
  description    String?
  monthlyPrice   Decimal   @map("monthly_price") @db.Decimal(12, 2)
  quarterlyPrice Decimal?  @map("quarterly_price") @db.Decimal(12, 2)
  annualPrice    Decimal?  @map("annual_price") @db.Decimal(12, 2)
  leadCap        Int?      @map("lead_cap") // null = unlimited
  isPublic       Boolean   @default(true) @map("is_public")
  isActive       Boolean   @default(true) @map("is_active")
  sortOrder      Int       @default(0) @map("sort_order")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organizations Organization[]
  planModules   PlanModule[]
  subscriptions Subscription[]

  @@map("plans")
  @@schema("billing")
}

/// Mapping of which modules a plan unlocks.
model PlanModule {
  id         String   @id @default(cuid())
  planId     String   @map("plan_id")
  moduleSlug String   @map("module_slug") // references platform.modules.slug (soft)
  createdAt  DateTime @default(now()) @map("created_at")

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, moduleSlug])
  @@index([planId])
  @@map("plan_modules")
  @@schema("billing")
}

/// Active subscription for an organization.
model Subscription {
  id                String             @id @default(cuid())
  orgId             String             @map("org_id")
  planId            String             @map("plan_id")
  status            SubscriptionStatus @default(TRIALING)
  billingCycle      BillingCycle       @default(ANNUAL) @map("billing_cycle")
  amount            Decimal            @db.Decimal(12, 2)
  discountPct       Int                @default(0) @map("discount_pct")
  trialEndsAt       DateTime?          @map("trial_ends_at")
  startedAt         DateTime?          @map("started_at")
  currentPeriodEnd  DateTime?          @map("current_period_end")
  graceEndsAt       DateTime?          @map("grace_ends_at")
  cancelAtPeriodEnd Boolean            @default(false) @map("cancel_at_period_end")
  gatewaySubId      String?            @map("gateway_sub_id") // Razorpay subscription id
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  deletedAt         DateTime?          @map("deleted_at")

  organization Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  plan         Plan               @relation(fields: [planId], references: [id])
  items        SubscriptionItem[]
  transactions Transaction[]

  @@index([orgId])
  @@index([status])
  @@map("subscriptions")
  @@schema("billing")
}

/// Line item within a subscription (module/add-on level).
model SubscriptionItem {
  id             String   @id @default(cuid())
  subscriptionId String   @map("subscription_id")
  moduleSlug     String   @map("module_slug")
  quantity       Int      @default(1)
  unitPrice      Decimal  @map("unit_price") @db.Decimal(12, 2)
  createdAt      DateTime @default(now()) @map("created_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@map("subscription_items")
  @@schema("billing")
}

/// Money movement record (GST 18%, SAC 998314; Razorpay-issued invoices).
model Transaction {
  id             String            @id @default(cuid())
  orgId          String            @map("org_id")
  subscriptionId String?           @map("subscription_id")
  type           TransactionType
  status         TransactionStatus @default(PENDING)
  amount         Decimal           @db.Decimal(12, 2)
  gstAmount      Decimal           @default(0) @map("gst_amount") @db.Decimal(12, 2)
  currency       String            @default("INR")
  gatewayRef     String?           @map("gateway_ref")
  invoiceUrl     String?           @map("invoice_url")
  metadata       Json? // credit purchases: { channel, packId, credits } — server-side grant truth
  paidAt         DateTime?         @map("paid_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([orgId])
  @@index([subscriptionId])
  @@index([status])
  @@map("transactions")
  @@schema("billing")
}

/// Per-org, per-channel message credit wallet. Free credits reset lazily
/// each UTC month (compared via periodStart); purchased credits never expire.
/// freeAllowance is edited by platform admins only.
model MessageWallet {
  id               String         @id @default(cuid())
  orgId            String         @map("org_id")
  channel          MessageChannel
  freeAllowance    Int            @default(25) @map("free_allowance")
  freeUsed         Int            @default(0) @map("free_used")
  purchasedBalance Int            @default(0) @map("purchased_balance")
  periodStart      DateTime       @default(now()) @map("period_start")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, channel])
  @@map("message_wallets")
  @@schema("billing")
}

/// Append-only credit movement trail. `ref` carries campaignId /
/// transactionId / admin userId depending on reason.
model MessageCreditLedger {
  id                    String             @id @default(cuid())
  orgId                 String             @map("org_id")
  channel               MessageChannel
  delta                 Int // negative = spend
  reason                CreditLedgerReason
  ref                   String?
  freeBalanceAfter      Int                @map("free_balance_after")
  purchasedBalanceAfter Int                @map("purchased_balance_after")
  note                  String?
  createdAt             DateTime           @default(now()) @map("created_at")

  @@index([orgId, channel, createdAt])
  @@index([ref])
  @@map("message_credit_ledger")
  @@schema("billing")
}

/// Bring-your-own messaging provider credentials (school's own MSG91
/// account). Auth key encrypted with the payments vault (AES-256-GCM).
/// A VERIFIED config makes sends bypass Vidhyaan credit metering.
model MessagingProviderConfig {
  id               String                  @id @default(cuid())
  orgId            String                  @map("org_id")
  channel          MessageChannel
  provider         String                  @default("MSG91")
  authKeyEncrypted String                  @map("auth_key_encrypted")
  encryptionKeyVer Int                     @default(1) @map("encryption_key_version")
  authKeyLast4     String?                 @map("auth_key_last4")
  senderId         String?                 @map("sender_id")
  smsFlowId        String?                 @map("sms_flow_id")
  whatsappNumber   String?                 @map("whatsapp_number")
  status           MessagingProviderStatus @default(DRAFT)
  verifiedAt       DateTime?               @map("verified_at")
  createdById      String?                 @map("created_by_id")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")
  deletedAt        DateTime?               @map("deleted_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, channel])
  @@map("messaging_provider_configs")
  @@schema("billing")
}

/// Referral program (Phase 2; fields scaffolded now per spec).
model Referral {
  id            String         @id @default(cuid())
  referrerOrgId String         @map("referrer_org_id") // soft reference to organizations
  refereeOrgId  String?        @map("referee_org_id") // soft reference
  code          String         @unique
  status        ReferralStatus @default(PENDING)
  rewardAmount  Decimal?       @map("reward_amount") @db.Decimal(12, 2)
  rewardedAt    DateTime?      @map("rewarded_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@index([referrerOrgId])
  @@index([status])
  @@map("referrals")
  @@schema("billing")
}

model PlatformSettings {
  id                    String   @id @default("default")
  freePlanLeadCap       Int      @default(10) @map("free_plan_lead_cap")
  trialDurationDays     Int      @default(7) @map("trial_duration_days")
  defaultOtpTtlMinutes  Int      @default(10) @map("default_otp_ttl_minutes")
  enableWhatsapp        Boolean  @default(false) @map("enable_whatsapp")
  enableCampaignModule  Boolean  @default(false) @map("enable_campaign_module")
  enableAiFeatures      Boolean  @default(false) @map("enable_ai_features")
  enablePublicApiAccess Boolean  @default(false) @map("enable_public_api_access")
  maintenanceMode       Boolean  @default(false) @map("maintenance_mode")
  fromEmailAddress      String?  @map("from_email_address")
  supportEmail          String?  @map("support_email")
  fromName              String?  @map("from_name")
  opsAlertEmail         String?  @map("ops_alert_email")
  slackWebhookUrl       String?  @map("slack_webhook_url")
  razorpayLiveKey       String?  @map("razorpay_live_key")
  razorpayWebhookSecret String?  @map("razorpay_webhook_secret")
  doSpacesEndpoint      String?  @map("do_spaces_endpoint")
  doSpacesBucket        String?  @map("do_spaces_bucket")
  doSpacesCdnUrl        String?  @map("do_spaces_cdn_url")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
  @@schema("platform")
}

model Term {
  id             String   @id @default(cuid())
  orgId          String   @map("org_id")
  academicYearId String   @map("academic_year_id")
  name           String
  startDate      DateTime @map("start_date")
  endDate        DateTime @map("end_date")
  order          Int      @default(0)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  invoices     Invoice[]

  @@index([orgId])
  @@index([academicYearId])
  @@map("terms")
  @@schema("crm")
}

model Course {
  id             String          @id @default(cuid())
  orgId          String          @map("org_id")
  name           String
  description    String?
  category       CenterCategory?
  amount         Decimal         @db.Decimal(10, 2)
  frequency      FeeFrequency    @default(MONTHLY)
  billingDay     Int             @default(1) @map("billing_day")
  durationMonths Int?            @map("duration_months")
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  deletedAt      DateTime?       @map("deleted_at")

  organization Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  enrollments  CourseEnrollment[]
  invoices     Invoice[]

  @@index([orgId])
  @@map("courses")
  @@schema("crm")
}

model CourseEnrollment {
  id              String           @id @default(cuid())
  orgId           String           @map("org_id")
  studentId       String           @map("student_id")
  courseId        String           @map("course_id")
  startDate       DateTime         @map("start_date")
  endDate         DateTime?        @map("end_date")
  status          EnrollmentStatus @default(ACTIVE)
  nextBillingDate DateTime?        @map("next_billing_date")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course       Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([orgId])
  @@index([studentId])
  @@index([courseId])
  @@map("course_enrollments")
  @@schema("crm")
}

enum AssignmentStatus {
  ACTIVE
  SUSPENDED
  REVOKED

  @@schema("platform")
}

model UserRoleAssignment {
  id         String           @id @default(cuid())
  userId     String           @map("user_id")
  role       UserRole
  orgId      String?          @map("org_id")
  status     AssignmentStatus @default(ACTIVE)
  isDefault  Boolean          @default(false)
  lastUsedAt DateTime?        @map("last_used_at")
  createdAt  DateTime         @default(now()) @map("created_at")

  user User          @relation(fields: [userId], references: [id])
  org  Organization? @relation(fields: [orgId], references: [id])

  @@unique([userId, role, orgId])
  @@index([userId])
  @@index([orgId])
  @@map("user_role_assignments")
  @@schema("platform")
}

// ============================================================
// PAYMENT GATEWAY (per-org fee collection — see
// docs/design/payment-gateway-integration.md)
// ============================================================

enum GatewayProvider {
  RAZORPAY
  STRIPE
  CASHFREE
  PAYU

  @@schema("billing")
}

enum GatewayEnvironment {
  TEST
  LIVE

  @@schema("billing")
}

enum GatewayConfigStatus {
  DRAFT
  VERIFIED
  ACTIVE
  DISABLED
  SUSPENDED

  @@schema("billing")
}

enum GatewayOrderStatus {
  CREATED
  ATTEMPTED
  PAID
  FAILED
  EXPIRED

  @@schema("billing")
}

enum RefundStatus {
  PENDING
  PROCESSED
  FAILED

  @@schema("billing")
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  SKIPPED
  FAILED

  @@schema("billing")
}

enum LedgerEntryType {
  CHARGE
  PAYMENT
  REFUND
  CONCESSION
  ADJUSTMENT

  @@schema("crm")
}

/// Per-org, per-provider, per-environment gateway credentials + policy.
/// Secrets encrypted with AES-256-GCM (src/lib/payments/vault.ts).
model PaymentGatewayConfig {
  id                 String              @id @default(cuid())
  orgId              String              @map("org_id")
  provider           GatewayProvider     @default(RAZORPAY)
  environment        GatewayEnvironment  @default(TEST)
  status             GatewayConfigStatus @default(DRAFT)
  isCurrent          Boolean             @default(false) @map("is_current")
  keyIdEncrypted     String              @map("key_id_encrypted")
  keySecretEncrypted String              @map("key_secret_encrypted")
  webhookSecretEnc   String              @map("webhook_secret_encrypted")
  encryptionKeyVer   Int                 @default(1) @map("encryption_key_version")
  keyIdLast4         String?             @map("key_id_last4")
  allowPartial       Boolean             @default(true) @map("allow_partial")
  minPartialAmount   Decimal?            @map("min_partial_amount") @db.Decimal(12, 2)
  verifiedAt         DateTime?           @map("verified_at")
  webhookVerifiedAt  DateTime?           @map("webhook_verified_at")
  lastWebhookAt      DateTime?           @map("last_webhook_at")
  createdById        String?             @map("created_by_id") // soft reference
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  deletedAt          DateTime?           @map("deleted_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, provider, environment])
  @@index([orgId, status])
  @@map("payment_gateway_configs")
  @@schema("billing")
}

/// One provider order per checkout intent; amount fixed at creation.
model GatewayOrder {
  id                String             @id @default(cuid())
  orgId             String             @map("org_id")
  provider          GatewayProvider
  environment       GatewayEnvironment
  invoiceId         String             @map("invoice_id")
  studentId         String?            @map("student_id") // soft reference
  parentId          String?            @map("parent_id") // soft reference; who initiated
  amount            Decimal            @db.Decimal(12, 2) // rupees; paise only at provider edge
  currency          String             @default("INR")
  status            GatewayOrderStatus @default(CREATED)
  providerOrderId   String             @map("provider_order_id")
  providerPaymentId String?            @map("provider_payment_id")
  failureCode       String?            @map("failure_code")
  failureReason     String?            @map("failure_reason")
  paymentId         String?            @unique @map("payment_id") // soft reference → crm.payments
  expiresAt         DateTime           @map("expires_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invoice      Invoice      @relation(fields: [invoiceId], references: [id])

  @@unique([provider, providerOrderId])
  @@index([orgId, status])
  @@index([orgId, invoiceId])
  @@index([status, expiresAt])
  @@map("gateway_orders")
  @@schema("billing")
}

/// Every inbound gateway webhook, verified or not — idempotency, audit, replay.
model WebhookEvent {
  id              String             @id @default(cuid())
  orgId           String?            @map("org_id") // soft reference; null if unresolvable
  provider        GatewayProvider
  providerEventId String             @map("provider_event_id")
  eventType       String             @map("event_type")
  status          WebhookEventStatus @default(RECEIVED)
  signatureValid  Boolean            @map("signature_valid")
  payload         Json
  error           String?
  processedAt     DateTime?          @map("processed_at")
  attempts        Int                @default(0)
  createdAt       DateTime           @default(now()) @map("created_at")

  @@unique([provider, providerEventId])
  @@index([orgId, createdAt])
  @@index([status, createdAt])
  @@map("webhook_events")
  @@schema("billing")
}

/// Gateway refund against a fee payment.
model Refund {
  id               String       @id @default(cuid())
  orgId            String       @map("org_id")
  paymentId        String       @map("payment_id")
  gatewayOrderId   String?      @map("gateway_order_id") // soft reference
  amount           Decimal      @db.Decimal(12, 2)
  status           RefundStatus @default(PENDING)
  providerRefundId String?      @map("provider_refund_id")
  reason           String?
  initiatedById    String       @map("initiated_by_id") // soft reference
  processedAt      DateTime?    @map("processed_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  payment      Payment      @relation(fields: [paymentId], references: [id])

  @@unique([orgId, providerRefundId])
  @@index([orgId, status])
  @@index([paymentId])
  @@map("refunds")
  @@schema("billing")
}

/// Append-only student money ledger. Debits = charges, credits = payments;
/// refund reversals are debits. Corrections are compensating ADJUSTMENT
/// entries — rows are never edited.
model LedgerEntry {
  id          String          @id @default(cuid())
  orgId       String          @map("org_id")
  studentId   String          @map("student_id")
  invoiceId   String?         @map("invoice_id") // soft reference
  paymentId   String?         @map("payment_id") // soft reference
  refundId    String?         @map("refund_id") // soft reference
  type        LedgerEntryType
  debit       Decimal         @default(0) @db.Decimal(12, 2)
  credit      Decimal         @default(0) @db.Decimal(12, 2)
  balance     Decimal         @db.Decimal(12, 2) // running balance snapshot
  description String
  createdAt   DateTime        @default(now()) @map("created_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [studentId], references: [id])

  @@index([orgId, studentId, createdAt])
  @@index([invoiceId])
  @@map("ledger_entries")
  @@schema("crm")
}

enum GuardianLinkStatus {
  INVITED
  ACTIVE
  REVOKED

  @@schema("crm")
}

/// Explicit, auditable link between a CRM student and a marketplace parent
/// account. Created when a school enables parent-portal access; supersedes
/// the implicit guardian-phone match (kept as bootstrap fallback).
model StudentGuardianLink {
  id          String             @id @default(cuid())
  orgId       String             @map("org_id")
  studentId   String             @map("student_id")
  parentId    String             @map("parent_id")
  relation    String? // FATHER / MOTHER / GUARDIAN — free text for now
  status      GuardianLinkStatus @default(INVITED)
  invitedById String?            @map("invited_by_id") // soft reference
  invitedAt   DateTime           @default(now()) @map("invited_at")
  activatedAt DateTime?          @map("activated_at") // first OTP login after invite
  revokedAt   DateTime?          @map("revoked_at")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent       Parent       @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([studentId, parentId])
  @@index([orgId, studentId])
  @@index([parentId, status])
  @@map("student_guardian_links")
  @@schema("crm")
}
